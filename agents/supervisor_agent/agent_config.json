      "get_global_context()": "Convenience method for business context",
      "read_individual_memory()": "Read agent's own memory file",
      "write_individual_memory(data)": "Write to agent's own memory file"
    },
    "usage_examples": {
      "share_learning": "self.add_learning('best_practices', {'content': 'Finding...', 'context': 'Task X'})",
      "read_system_state": "state = self.get_system_state()",
      "check_infrastructure": "models = state.get('infrastructure', {}).get('ai_models', {})",
      "persist_own_data": "self.write_individual_memory({'last_task': 'completed', 'metrics': {...}})"
    }
