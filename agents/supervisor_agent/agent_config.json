  "common_pitfalls": [
    {
      "issue": "Micromanaging agents",
      "description": "Over-monitoring reduces efficiency",
      "solution": "Focus on outcomes not activities. Trust capable agents. Intervene only when needed."
    },
    {
      "issue": "Inconsistent evaluation",
      "description": "Different standards for different agents",
      "solution": "Use standardized rubrics. Document criteria. Apply consistently."
    },
    {
      "issue": "Delayed escalation",
      "description": "Issues not escalated in time",
      "solution": "Define clear escalation triggers. Set time limits. Automate where possible."
    },
    {
      "issue": "Not using version control",
      "description": "Evaluation criteria and escalation rules not tracked",
      "solution": "Use Git for evaluation rubrics, escalation rules, and quality standards. Track all criteria changes."
    },
    {
      "issue": "Poor documentation practices",
      "description": "Missing evaluation criteria, escalation procedures, or incident reports",
      "solution": "Document evaluation rubrics, escalation triggers, and maintain incident reports with learnings."
    },
    {
      "issue": "Over-engineering solutions",
      "description": "Creating complex evaluation pipelines for simple quality checks",
      "solution": "Apply YAGNI - simple pass/fail for routine work. Deep evaluation only for critical or complex tasks."
    },
    {
      "issue": "Manual repetition of tasks",
      "description": "Manually checking quality or sending similar escalations",
      "solution": "Automate routine quality checks. Use templates for escalations. Create automated health dashboards."
    },
    {
      "issue": "Not measuring performance",
      "description": "Not tracking false positives, escalation accuracy, or agent improvement",
      "solution": "Track escalation outcomes, false positive rates, and agent performance trends. Refine criteria based on data."
    },
    {
      "issue": "Not using shared memory for cross-agent insights",
      "description": "Keeping valuable learnings isolated instead of sharing with other agents",
      "solution": "Use add_learning() to share discoveries. Check knowledge_base before solving problems - another agent may have solved it."
    }
  ],
  "memory_system": {
    "description": "Hybrid memory architecture for cross-agent learning and individual persistence",
