.border-b { border-bottom-width: 1px; border-bottom-style: solid; border-color: var(--color-border, #e5e7eb); }
.border-white { border-color: #fff; }
.border-white\/20 { border-color: rgba(255,255,255,0.2); }
.border-white\/40 { border-color: rgba(255,255,255,0.4); }
.border-gray-700 { border-color: #374151; }
.divide-y > * + * { border-top-width: 1px; border-top-style: solid; border-color: var(--color-border, #e5e7eb); }
.rounded-full { border-radius: 9999px; }
.rounded-md { border-radius: 0.375rem; }

/* -- Shadows -- */
.shadow-sm { box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); }
.shadow-md { box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1); }
.shadow-lg { box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1); }
.shadow-xl { box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1); }
.shadow-2xl { box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); }

/* -- Effects -- */
.opacity-0 { opacity: 0; }
.opacity-40 { opacity: 0.4; }
.opacity-70 { opacity: 0.7; }
.opacity-90 { opacity: 0.9; }
.overflow-hidden { overflow: hidden; }
.overflow-x-auto { overflow-x: auto; }
.object-cover { object-fit: cover; }
.object-contain { object-fit: contain; }
.grayscale { filter: grayscale(100%); }
.cursor-pointer { cursor: pointer; }
.antialiased { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

/* -- Transitions -- */
.transition { transition-property: color, background-color, border-color, text-decoration-color, fill, stroke, opacity, box-shadow, transform, filter, backdrop-filter; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
.transition-all { transition-property: all; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
.transition-colors { transition-property: color, background-color, border-color, text-decoration-color, fill, stroke; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
.transition-opacity { transition-property: opacity; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
.transition-transform { transition-property: transform; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
.duration-200 { transition-duration: 200ms; }
.duration-300 { transition-duration: 300ms; }

/* -- Transform -- */
.-translate-x-1\/2 { transform: translateX(-50%); }

/* -- Group & Interactive States -- */
.group { position: relative; }

/* -- Prose Spacing -- */
.prose-spacing > * + * { margin-top: 1em; }

/* -- Hover States -- */
.hover\:underline:hover { text-decoration: underline; }
.hover\:text-primary:hover { color: var(--color-primary); }
.hover\:text-white:hover { color: #fff; }
.hover\:text-white\/80:hover { color: rgba(255,255,255,0.8); }
.hover\:bg-gray-50:hover { background-color: #f9fafb; }
.hover\:bg-gray-100:hover { background-color: #f3f4f6; }
.hover\:bg-white\/10:hover { background-color: rgba(255,255,255,0.1); }
.hover\:border-white:hover { border-color: #fff; }
.hover\:opacity-100:hover { opacity: 1; }
.hover\:scale-105:hover { transform: scale(1.05); }
.hover\:grayscale-0:hover { filter: grayscale(0); }

/* -- Focus States -- */
.focus\:outline-none:focus { outline: 2px solid transparent; outline-offset: 2px; }
.focus\:ring-2:focus { box-shadow: 0 0 0 2px var(--tw-ring-color, rgba(59,130,246,0.5)); }
.focus\:ring-white:focus { --tw-ring-color: #fff; }
.focus\:ring-inset:focus { box-shadow: inset 0 0 0 2px var(--tw-ring-color, rgba(59,130,246,0.5)); }
.focus\:ring-offset-0:focus { --tw-ring-offset-width: 0px; }

/* -- Group Hover / Open States -- */
.group:hover .group-hover\:opacity-100 { opacity: 1; }
.group:hover .group-hover\:scale-105 { transform: scale(1.05); }
details[open] > .group-open\:rotate-180,
.group.open .group-open\:rotate-180 { transform: rotate(180deg); }

/* ---- Responsive: sm (min-width: 640px) ---- */
@media (min-width: 640px) {
    .sm\:flex-row { flex-direction: row; }
    .sm\:flex-shrink-0 { flex-shrink: 0; }
    .sm\:items-start { align-items: flex-start; }
    .sm\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .sm\:columns-2 { columns: 2; }
    .sm\:gap-4 { gap: 1rem; }
    .sm\:gap-8 { gap: 2rem; }
    .sm\:gap-12 { gap: 3rem; }
    .sm\:p-6 { padding: 1.5rem; }
    .sm\:p-8 { padding: 2rem; }
    .sm\:p-12 { padding: 3rem; }
    .sm\:px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
    .sm\:py-8 { padding-top: 2rem; padding-bottom: 2rem; }
    .sm\:py-16 { padding-top: 4rem; padding-bottom: 4rem; }
    .sm\:py-20 { padding-top: 5rem; padding-bottom: 5rem; }
    .sm\:py-28 { padding-top: 7rem; padding-bottom: 7rem; }
    .sm\:py-36 { padding-top: 9rem; padding-bottom: 9rem; }
    .sm\:pt-2 { padding-top: 0.5rem; }
    .sm\:pl-20 { padding-left: 5rem; }
    .sm\:mb-16 { margin-bottom: 4rem; }
    .sm\:left-6 { left: 1.5rem; }
    .sm\:w-12 { width: 3rem; }
    .sm\:w-36 { width: 9rem; }
    .sm\:w-auto { width: auto; }
    .sm\:h-10 { height: 2.5rem; }
    .sm\:h-12 { height: 3rem; }
    .sm\:h-72 { height: 18rem; }
    .sm\:h-full { height: 100%; }
    .sm\:min-h-\[600px\] { min-height: 600px; }
    .sm\:text-base { font-size: 1rem; line-height: 1.5rem; }
    .sm\:text-xl { font-size: 1.25rem; line-height: 1.75rem; }
    .sm\:text-2xl { font-size: 1.5rem; line-height: 2rem; }
    .sm\:text-3xl { font-size: 1.875rem; line-height: 2.25rem; }
    .sm\:text-4xl { font-size: 2.25rem; line-height: 2.5rem; }
    .sm\:text-5xl { font-size: 3rem; line-height: 1; }
    .sm\:text-6xl { font-size: 3.75rem; line-height: 1; }
    .sm\:text-right { text-align: right; }
    .sm\:space-y-16 > * + * { margin-top: 4rem; }
    .sm\:space-y-24 > * + * { margin-top: 6rem; }
}

/* ---- Responsive: md (min-width: 768px) ---- */
@media (min-width: 768px) {
    .md\:flex { display: flex; }
    .md\:block { display: block; }
    .md\:hidden { display: none; }
    .md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .md\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .md\:grid-cols-6 { grid-template-columns: repeat(6, minmax(0, 1fr)); }
    .md\:columns-3 { columns: 3; }
    .md\:scale-105 { transform: scale(1.05); }
}

/* ---- Responsive: lg (min-width: 1024px) ---- */
@media (min-width: 1024px) {
    .lg\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .lg\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .lg\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .lg\:grid-cols-5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }
    .lg\:col-span-2 { grid-column: span 2 / span 2; }
    .lg\:col-span-3 { grid-column: span 3 / span 3; }
    .lg\:columns-4 { columns: 4; }
    .lg\:gap-12 { gap: 3rem; }
    .lg\:gap-16 { gap: 4rem; }
    .lg\:max-w-lg { max-width: 32rem; }
    .lg\:pl-8 { padding-left: 2rem; }
    .lg\:px-8 { padding-left: 2rem; padding-right: 2rem; }
    .lg\:py-24 { padding-top: 6rem; padding-bottom: 6rem; }
    .lg\:py-28 { padding-top: 7rem; padding-bottom: 7rem; }
    .lg\:py-36 { padding-top: 9rem; padding-bottom: 9rem; }
    .lg\:py-44 { padding-top: 11rem; padding-bottom: 11rem; }
    .lg\:h-80 { height: 20rem; }
    .lg\:text-5xl { font-size: 3rem; line-height: 1; }
    .lg\:text-6xl { font-size: 3.75rem; line-height: 1; }
    .lg\:text-7xl { font-size: 4.5rem; line-height: 1; }
}

/* ---- Benchmarks ---- */
.bench-hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-top: 2rem;
    flex-wrap: wrap;
}
.bench-hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
}
.bench-hero-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: var(--font-heading-weight);
    color: var(--color-primary);
    line-height: 1;
}
.bench-hero-label {
    font-size: 0.85rem;
    margin-top: 0.5rem;
    opacity: 0.7;
}
@media (min-width: 640px) {
    .bench-hero-number { font-size: 2.75rem; }
    .bench-hero-stats { gap: 4rem; }
}

.bench-table-wrap {
    overflow-x: auto;
    margin-top: 1.5rem;
}
.bench-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
}
.bench-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--color-secondary);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
}
.bench-table td {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid #e5e7eb;
    vertical-align: middle;
}
.bench-table tbody tr:hover {
    background: {{ brand.accent_color }};
}
.bench-agent-name {
    font-weight: 600;
    white-space: nowrap;
}
.bench-score-cell {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 160px;
}
.bench-bar-track {
    flex: 1;
    height: 8px;
    background: #e5e7eb;
    border-radius: 4px;
    overflow: hidden;
}
.bench-bar-fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 4px;
    transition: width 0.6s ease;
}
.bench-score-pct {
    font-weight: 700;
    font-size: 0.85rem;
    min-width: 3rem;
    text-align: right;
}
.bench-cat-count {
    text-align: center;
    font-weight: 600;
}

.bench-diff-tag {
    display: inline-block;
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    margin-right: 0.25rem;
    font-weight: 600;
}
.bench-diff-int { background: #d1fae5; color: #065f46; }
.bench-diff-adv { background: #fef3c7; color: #92400e; }
.bench-diff-exp { background: #fce7f3; color: #9d174d; }

.bench-hide-mobile { display: none; }
@media (min-width: 768px) {
    .bench-hide-mobile { display: table-cell; }
}

.bench-score-badge {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: var(--font-heading-weight);
    color: var(--color-primary);
}

.bench-cat-grid {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
}
.bench-cat-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
}
.bench-cat-bar-track {
    height: 6px;
    background: #e5e7eb;
    border-radius: 3px;
    overflow: hidden;
}
.bench-cat-bar-fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 3px;
}
.bench-cat-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
}
.bench-cat-name {
    opacity: 0.7;
    text-transform: capitalize;
}
.bench-cat-score {
    font-weight: 600;
}

/* ---- Accessibility: Reduced Motion ---- */
@media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
    }
}

/* ---- Print ---- */
@media print {
    .site-nav, .mobile-toggle, .btn-primary, .btn-secondary { display: none; }
    .site-footer { padding: 1rem 0; }
    body { color: #000; background: #fff; }
    a { color: #000; text-decoration: underline; }
    .card { box-shadow: none; border: 1px solid #ccc; }
}
