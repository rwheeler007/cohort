{# Booking Widget: Large CTA section for appointment booking.
   Tags: bold, warm
   Variables: block.heading, block.description, block.booking_url, block.button_text, block.phone
#}
<section class="section-primary">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-24 text-center">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white" style="font-family: var(--font-heading);">
      {{ block.heading }}
    </h2>

    {% if block.description %}
    <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto leading-relaxed">
      {{ block.description }}
    </p>
    {% endif %}

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      {% if block.button_text %}
      <a href="{{ block.booking_url | default('#') }}" class="inline-block px-10 py-4 text-lg font-bold bg-white rounded-theme hover:bg-gray-100 transition-colors w-full sm:w-auto text-center" style="color: var(--color-primary);">
        {{ block.button_text }}
      </a>
      {% endif %}

      {% if block.phone %}
      <a href="tel:{{ block.phone }}" class="inline-flex items-center justify-center gap-2 px-8 py-4 text-lg font-semibold text-white border-2 border-white/40 rounded-theme hover:border-white transition-colors w-full sm:w-auto">
        <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span>{{ block.phone }}</span>
      </a>
      {% endif %}
    </div>
  </div>
</section>
