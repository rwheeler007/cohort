{# Gallery: Masonry-style layout using CSS columns. Variable-height images.
   Tags: creative, modern
   Variables: block.section_headline, block.images [{src, alt, caption}]
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {% if block.section_headline %}
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold" style="font-family: var(--font-heading);">{{ block.section_headline }}</h2>
    </div>
    {% endif %}

    <div style="columns: 2; column-gap: 1rem;" class="sm:columns-2 md:columns-3 lg:columns-4">
      {% for image in block.images %}
      <figure class="relative group overflow-hidden rounded-theme mb-4 break-inside-avoid">
        <img src="{{ image.src }}" alt="{{ image.alt }}" class="w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy">
        {% if image.caption %}
        <figcaption class="absolute inset-0 flex items-end bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <span class="p-3 text-sm text-white leading-snug">{{ image.caption }}</span>
        </figcaption>
        {% endif %}
      </figure>
      {% endfor %}
    </div>
  </div>
</section>
<style>
  @media (min-width: 640px) {
    .sm\:columns-2 { columns: 2 !important; }
  }
  @media (min-width: 768px) {
    .md\:columns-3 { columns: 3 !important; }
  }
  @media (min-width: 1024px) {
    .lg\:columns-4 { columns: 4 !important; }
  }
</style>
