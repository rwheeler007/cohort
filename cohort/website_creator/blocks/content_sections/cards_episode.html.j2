{# Cards: Episode/podcast cards with badge, title, description, duration, and guests.
   Tags: podcast, episode, media
   Variables: block.items [{title, excerpt, badge, duration, guests, href}]
   - badge: episode label (e.g. "Episode #101")
   - duration: playback time (e.g. "48:32 minutes")
   - guests: list of {name, href} objects
#}
<section class="section-spacing py-16 sm:py-20 lg:py-24">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
    {% for item in block.items %}
    <article class="rounded-xl p-4 sm:p-6 lg:p-8" style="background: var(--color-surface, #fff); box-shadow: 0 0 0 3px var(--color-accent-light, #e0e7ff);">
      <div class="flex items-start sm:gap-8">
        {# Audio icon (decorative) #}
        <div class="hidden sm:grid sm:size-20 sm:shrink-0 sm:place-content-center sm:rounded-full" style="border: 2px solid var(--color-primary);" aria-hidden="true">
          <div class="flex items-center gap-1">
            <span class="h-8 w-0.5 rounded-full" style="background: var(--color-primary);"></span>
            <span class="h-6 w-0.5 rounded-full" style="background: var(--color-primary);"></span>
            <span class="h-4 w-0.5 rounded-full" style="background: var(--color-primary);"></span>
            <span class="h-6 w-0.5 rounded-full" style="background: var(--color-primary);"></span>
            <span class="h-8 w-0.5 rounded-full" style="background: var(--color-primary);"></span>
          </div>
        </div>

        <div>
          {% if item.badge %}
          <strong
            class="rounded-sm px-3 py-1.5 text-[10px] font-medium text-white"
            style="background: var(--color-primary); border: 1px solid var(--color-primary);"
          >
            {{ item.badge }}
          </strong>
          {% endif %}

          <h3 class="mt-4 text-lg font-medium sm:text-xl" style="font-family: var(--font-heading);">
            <a href="{{ item.href | default('#') }}" class="hover:underline" style="color: var(--color-text);">
              {{ item.title }}
            </a>
          </h3>

          {% if item.excerpt %}
          <p class="mt-1 text-sm" style="color: var(--color-text-muted);">
            {{ item.excerpt }}
          </p>
          {% endif %}

          {% if item.duration or item.guests %}
          <div class="mt-4 sm:flex sm:items-center sm:gap-2">
            {% if item.duration %}
            <div class="flex items-center gap-1" style="color: var(--color-text-muted);">
              <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <p class="text-xs font-medium">{{ item.duration }}</p>
            </div>
            {% endif %}

            {% if item.duration and item.guests %}
            <span class="hidden sm:block" aria-hidden="true">&middot;</span>
            {% endif %}

            {% if item.guests %}
            <p class="mt-2 text-xs font-medium sm:mt-0" style="color: var(--color-text-muted);">
              Featuring
              {% for guest in item.guests %}
                <a href="{{ guest.href | default('#') }}" class="underline" style="color: var(--color-text-muted);">{{ guest.name }}</a>{% if not loop.last %}{% if loop.revindex == 2 %} and {% else %}, {% endif %}{% endif %}
              {% endfor %}
            </p>
            {% endif %}
          </div>
          {% endif %}
        </div>
      </div>
    </article>
    {% endfor %}
  </div>
</section>
