{# Content: Generic prose sections with heading, body, optional bullet lists.
   Tags: conventional
   Variables: block.sections [{heading, body, list_items}]
#}
<section class="bg-white py-16 sm:py-20 lg:py-24">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    {% for section in block.sections %}
    <div class="{% if not loop.first %}mt-12 pt-12 border-t border-theme{% endif %}">
      {% if section.heading %}
      <h2 class="text-2xl sm:text-3xl font-bold mb-4" style="font-family: var(--font-heading);">{{ section.heading }}</h2>
      {% endif %}
      {% if section.body %}
      <div class="text-muted leading-relaxed prose-spacing">
        {{ section.body }}
      </div>
      {% endif %}
      {% if section.list_items %}
      <ul class="mt-4 space-y-2">
        {% for item in section.list_items %}
        <li class="flex items-start gap-3 text-muted">
          <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span>{{ item }}</span>
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</section>
