{# Cards: Forum/thread cards with avatar, title, excerpt, comment count, author, and status badge.
   Tags: forum, thread, community
   Variables: block.items [{image, title, excerpt, author, comment_count, status, href}]
   - status: optional badge text (e.g. "Solved!" or "Open")
   - comment_count: e.g. "14 comments"
#}
<section class="section-spacing py-16 sm:py-20 lg:py-24">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
    {% for item in block.items %}
    <article class="rounded-xl border-2" style="background: var(--color-surface, #fff); border-color: var(--color-border, #e5e7eb);">
      <div class="flex items-start gap-4 p-4 sm:p-6 lg:p-8">
        {% if item.image | default('') %}
        <a href="{{ item.href | default('#') }}" class="block shrink-0">
          <img
            src="{{ item.image }}"
            alt="{{ item.author | default(item.title) }}"
            class="size-14 rounded-lg object-cover"
            loading="lazy"
          />
        </a>
        {% endif %}

        <div>
          <h3 class="font-medium sm:text-lg" style="font-family: var(--font-heading);">
            <a href="{{ item.href | default('#') }}" class="hover:underline" style="color: var(--color-text);">
              {{ item.title }}
            </a>
          </h3>

          {% if item.excerpt %}
          <p class="line-clamp-2 text-sm" style="color: var(--color-text-muted);">
            {{ item.excerpt }}
          </p>
          {% endif %}

          <div class="mt-2 sm:flex sm:items-center sm:gap-2">
            {% if item.comment_count %}
            <div class="flex items-center gap-1" style="color: var(--color-text-muted);">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
              </svg>
              <p class="text-xs">{{ item.comment_count }}</p>
            </div>
            {% endif %}

            {% if item.comment_count and item.author %}
            <span class="hidden sm:block" aria-hidden="true">&middot;</span>
            {% endif %}

            {% if item.author %}
            <p class="hidden sm:block sm:text-xs" style="color: var(--color-text-muted);">
              Posted by
              <a href="{{ item.href | default('#') }}" class="font-medium underline" style="color: var(--color-text-muted);">
                {{ item.author }}
              </a>
            </p>
            {% endif %}
          </div>
        </div>
      </div>

      {% if item.status %}
      <div class="flex justify-end">
        <strong
          class="-me-0.5 -mb-0.5 inline-flex items-center gap-1 rounded-ss-xl rounded-ee-xl px-3 py-1.5 text-white"
          style="background: var(--color-accent, #16a34a);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          <span class="text-[10px] font-medium sm:text-xs">{{ item.status }}</span>
        </strong>
      </div>
      {% endif %}
    </article>
    {% endfor %}
  </div>
</section>
