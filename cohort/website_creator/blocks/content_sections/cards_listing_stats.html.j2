{# Cards: Listing/property cards with image, price, title, and stat icons.
   Tags: listing, real-estate, stats
   Variables: block.items [{image, title, subtitle, href, stats}]
   - subtitle: price or secondary info (e.g. "$240,000")
   - stats: list of {label, value} objects (e.g. [{label: "Parking", value: "2 spaces"}])
#}
<section class="section-spacing py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for item in block.items %}
      <a href="{{ item.href | default('#') }}" class="block rounded-lg p-4 shadow-sm" style="background: var(--color-surface, #fff);">
        {% if item.image | default('') %}
        <img
          src="{{ item.image }}"
          alt="{{ item.title }}"
          class="h-56 w-full rounded-md object-cover"
          loading="lazy"
        />
        {% else %}
        <div class="h-56 w-full rounded-md flex items-center justify-center" style="background: var(--color-accent-light, #f3f4f6);">
          <span class="text-sm" style="color: var(--color-text-muted);">Image</span>
        </div>
        {% endif %}

        <div class="mt-2">
          {% if item.subtitle %}
          <p class="text-sm" style="color: var(--color-text-muted);">{{ item.subtitle }}</p>
          {% endif %}

          <h3 class="font-medium" style="color: var(--color-text); font-family: var(--font-heading);">
            {{ item.title }}
          </h3>

          {% if item.stats %}
          <div class="mt-6 flex items-center gap-8 text-xs">
            {% for stat in item.stats %}
            <div class="sm:inline-flex sm:shrink-0 sm:items-center sm:gap-2">
              <svg class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--color-primary);">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M5 13l4 4L19 7" />
              </svg>
              <div class="mt-1.5 sm:mt-0">
                <p style="color: var(--color-text-muted);">{{ stat.label }}</p>
                <p class="font-medium" style="color: var(--color-text);">{{ stat.value }}</p>
              </div>
            </div>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
