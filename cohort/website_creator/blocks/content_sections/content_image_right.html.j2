{# Content: 50/50 split with heading and text on left, image on right.
   Tags: conventional, balanced
   Variables: block.heading, block.body, block.image
#}
<section class="section-spacing">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 md:items-center md:gap-8">
      <div>
        <div class="max-w-prose md:max-w-none">
          {% if block.heading %}
          <h2 class="text-2xl font-semibold sm:text-3xl" style="color: var(--color-text); font-family: var(--font-heading);">
            {{ block.heading }}
          </h2>
          {% endif %}

          {% if block.body %}
          <p class="mt-4 text-pretty" style="color: var(--color-text-muted);">
            {{ block.body }}
          </p>
          {% endif %}
        </div>
      </div>

      <div>
        {% if block.image %}
        <img
          src="{{ block.image }}"
          alt="{{ block.heading | default('') }}"
          class="rounded"
          loading="lazy"
        />
        {% endif %}
      </div>
    </div>
  </div>
</section>
