{# Cards: Dashed-border card with icon, hover reveals full description. Playful offset effect.
   Tags: creative, interactive
   Variables: block.items [{title, excerpt, href, icon_svg}]
   - icon_svg: optional inline SVG string for the card icon
#}
<section class="section-spacing py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for item in block.items %}
      <a href="{{ item.href | default('#') }}" class="group relative block h-64 sm:h-80 lg:h-96">
        <span class="absolute inset-0 border-2 border-dashed" style="border-color: var(--color-text);"></span>

        <div
          class="relative flex h-full transform items-end border-2 transition-transform group-hover:-translate-x-2 group-hover:-translate-y-2"
          style="border-color: var(--color-text); background: var(--color-surface, #fff);"
        >
          {# Default state: icon + title #}
          <div class="px-4 pb-4 transition-opacity group-hover:absolute group-hover:opacity-0 sm:px-6 sm:pb-4 lg:px-8 lg:pb-8">
            {% if item.icon_svg %}
              {{ item.icon_svg | safe }}
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" class="size-10 sm:size-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            {% endif %}

            <h2 class="mt-4 text-xl font-medium sm:text-2xl" style="color: var(--color-text); font-family: var(--font-heading);">
              {{ item.title }}
            </h2>
          </div>

          {# Hover state: title + excerpt + read more #}
          <div class="absolute p-4 opacity-0 transition-opacity group-hover:relative group-hover:opacity-100 sm:p-6 lg:p-8">
            <h3 class="mt-4 text-xl font-medium sm:text-2xl" style="color: var(--color-text); font-family: var(--font-heading);">
              {{ item.title }}
            </h3>

            {% if item.excerpt %}
            <p class="mt-4 text-sm sm:text-base" style="color: var(--color-text-muted);">
              {{ item.excerpt }}
            </p>
            {% endif %}

            <p class="mt-8 font-bold" style="color: var(--color-text);">Read more</p>
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
