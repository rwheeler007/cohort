{# Cards: Full-bleed image background with hover-reveal description overlay.
   Tags: dramatic, interactive, team
   Variables: block.items [{image, title, subtitle, excerpt, href}]
   - subtitle: role or category label shown above the name (e.g. "Developer")
#}
<section class="section-spacing py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for item in block.items %}
      <a href="{{ item.href | default('#') }}" class="group relative block" style="background: #000;">
        {% if item.image | default('') %}
        <img
          src="{{ item.image }}"
          alt="{{ item.title }}"
          class="absolute inset-0 h-full w-full object-cover opacity-75 transition-opacity group-hover:opacity-50"
          loading="lazy"
        />
        {% endif %}

        <div class="relative p-4 sm:p-6 lg:p-8">
          {% if item.subtitle %}
          <p class="text-sm font-medium tracking-widest uppercase" style="color: var(--color-primary);">
            {{ item.subtitle }}
          </p>
          {% endif %}

          <p class="text-xl font-bold text-white sm:text-2xl" style="font-family: var(--font-heading);">
            {{ item.title }}
          </p>

          <div class="mt-32 sm:mt-48 lg:mt-64">
            <div class="translate-y-8 transform opacity-0 transition-all group-hover:translate-y-0 group-hover:opacity-100">
              {% if item.excerpt %}
              <p class="text-sm text-white">
                {{ item.excerpt }}
              </p>
              {% endif %}
            </div>
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
