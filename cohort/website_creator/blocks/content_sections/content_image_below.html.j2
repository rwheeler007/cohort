{# Content: Stacked layout with heading and text on top, full-width image below.
   Tags: editorial, stacked
   Variables: block.heading, block.body, block.image
#}
<section class="section-spacing">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="space-y-4 md:space-y-8">
      <div class="max-w-prose">
        {% if block.heading %}
        <h2 class="text-2xl font-semibold sm:text-3xl" style="color: var(--color-text); font-family: var(--font-heading);">
          {{ block.heading }}
        </h2>
        {% endif %}

        {% if block.body %}
        <p class="mt-4 text-pretty" style="color: var(--color-text-muted);">
          {{ block.body }}
        </p>
        {% endif %}
      </div>

      {% if block.image %}
      <img
        src="{{ block.image }}"
        alt="{{ block.heading | default('') }}"
        class="rounded"
        loading="lazy"
      />
      {% endif %}
    </div>
  </div>
</section>
