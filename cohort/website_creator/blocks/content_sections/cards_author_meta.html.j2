{# Cards: Author card with avatar, title, excerpt, date, and reading time metadata.
   Tags: conventional, blog, author
   Variables: block.items [{image, title, author, excerpt, date, reading_time, href}]
   - image: author avatar (circular)
   - reading_time: e.g. "12 minutes"
#}
<section class="section-spacing py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for item in block.items %}
      <a href="{{ item.href | default('#') }}"
         class="block rounded-md border p-4 shadow-sm sm:p-6"
         style="border-color: var(--color-border, #d1d5db);">
        <div class="sm:flex sm:justify-between sm:gap-4 lg:gap-6">
          {% if item.image | default('') %}
          <div class="sm:order-last sm:shrink-0">
            <img
              src="{{ item.image }}"
              alt="{{ item.author | default(item.title) }}"
              class="size-16 rounded-full object-cover sm:size-18"
              loading="lazy"
            />
          </div>
          {% endif %}

          <div class="mt-4 sm:mt-0">
            <h3 class="text-lg font-medium text-pretty" style="color: var(--color-text); font-family: var(--font-heading);">
              {{ item.title }}
            </h3>

            {% if item.author %}
            <p class="mt-1 text-sm" style="color: var(--color-text-muted);">By {{ item.author }}</p>
            {% endif %}

            {% if item.excerpt %}
            <p class="mt-4 line-clamp-2 text-sm text-pretty" style="color: var(--color-text-muted);">
              {{ item.excerpt }}
            </p>
            {% endif %}
          </div>
        </div>

        {% if item.date or item.reading_time %}
        <dl class="mt-6 flex gap-4 lg:gap-6">
          {% if item.date %}
          <div class="flex items-center gap-2">
            <dt style="color: var(--color-text-muted);">
              <span class="sr-only">Published on</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
              </svg>
            </dt>
            <dd class="text-xs" style="color: var(--color-text-muted);">{{ item.date }}</dd>
          </div>
          {% endif %}

          {% if item.reading_time %}
          <div class="flex items-center gap-2">
            <dt style="color: var(--color-text-muted);">
              <span class="sr-only">Reading time</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
              </svg>
            </dt>
            <dd class="text-xs" style="color: var(--color-text-muted);">{{ item.reading_time }}</dd>
          </div>
          {% endif %}
        </dl>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </div>
</section>
