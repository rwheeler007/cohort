{# Chef/Owner: Split layout with photo left, bio text right.
   Tags: warm, conventional
   Variables: block.name, block.title, block.photo, block.bio_paragraphs (list of strings)
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      {# Photo #}
      <div>
        {% if block.photo %}
        <img src="{{ block.photo }}" alt="Photo of {{ block.name }}" class="w-full max-w-md mx-auto rounded-theme object-cover aspect-[3/4]" loading="lazy">
        {% else %}
        <div class="w-full max-w-md mx-auto rounded-theme bg-alt aspect-[3/4] flex items-center justify-center">
          <span class="text-muted text-sm">Photo</span>
        </div>
        {% endif %}
      </div>

      {# Bio #}
      <div>
        {% if block.name %}
        <h2 class="text-3xl sm:text-4xl font-bold mb-2" style="font-family: var(--font-heading);">{{ block.name }}</h2>
        {% endif %}
        {% if block.title %}
        <p class="text-primary text-lg font-medium mb-6">{{ block.title }}</p>
        {% endif %}
        {% if block.bio_paragraphs %}
        <div class="space-y-4">
          {% for paragraph in block.bio_paragraphs %}
          <p class="text-muted leading-relaxed">{{ paragraph }}</p>
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
