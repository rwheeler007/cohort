<!doctype html>
<html lang="{{ site.language | default('en') }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title | default(site.product_name) }}</title>
  <meta name="description" content="{{ page.meta_description | default('') }}">
  {% if page.meta_keywords %}<meta name="keywords" content="{{ page.meta_keywords | join(', ') }}">{% endif %}
  {% if site.favicon %}<link rel="icon" href="{{ site.favicon }}">{% endif %}
  {% if site.brand and site.brand.primary_color %}<meta name="theme-color" content="{{ site.brand.primary_color }}">{% endif %}
  {% if site.seo %}
  {% if site.seo.canonical_base %}<link rel="canonical" href="{{ site.seo.canonical_base }}/{{ page.slug | default('index') }}.html">{% endif %}
  <meta property="og:title" content="{{ page.title | default(site.product_name) }}">
  <meta property="og:description" content="{{ page.meta_description | default('') }}">
  <meta property="og:type" content="website">
  {% if site.seo.canonical_base %}<meta property="og:url" content="{{ site.seo.canonical_base }}/{{ page.slug | default('index') }}.html">{% endif %}
  {% if site.seo.og_image %}<meta property="og:image" content="{{ site.seo.og_image }}">{% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page.title | default(site.product_name) }}">
  <meta name="twitter:description" content="{{ page.meta_description | default('') }}">
  {% if site.seo.og_image %}<meta name="twitter:image" content="{{ site.seo.og_image }}">{% endif %}
  {% if site.seo.twitter_handle %}<meta name="twitter:site" content="{{ site.seo.twitter_handle }}">{% endif %}
  {% endif %}
  {% if site.seo and site.seo.ga_measurement_id %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.seo.ga_measurement_id }}"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','{{ site.seo.ga_measurement_id }}');</script>
  {% endif %}
  {% if skin.google_fonts %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family={{ skin.google_fonts | join('&family=') | replace(' ', '+') }}&display=swap" rel="stylesheet">
  {% endif %}
  {% if site.jsonld %}
  <script type="application/ld+json">{{ site.jsonld }}</script>
  {% endif %}
  {% include "blocks/_tokens.html.j2" %}
</head>
<body class="antialiased">
  {% for block in page.blocks %}
  {% include "blocks/" ~ block.type ~ "/" ~ block.variant ~ ".html.j2" %}
  {% endfor %}
</body>
</html>
