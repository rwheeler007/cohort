{# Specials: Large featured cards with big images, dish name, description, price.
   Tags: bold, warm
   Variables: block.heading, block.specials [{name, description, image, price}]
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {% if block.heading %}
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold" style="font-family: var(--font-heading);">{{ block.heading }}</h2>
    </div>
    {% endif %}

    <div class="grid grid-cols-1 {% if block.specials | length > 1 %}md:grid-cols-2{% endif %} gap-8">
      {% for special in block.specials %}
      <article class="bg-white border border-theme rounded-theme overflow-hidden">
        {% if special.image %}
        <div class="aspect-video overflow-hidden">
          <img src="{{ special.image }}" alt="{{ special.name }}" class="w-full h-full object-cover" loading="lazy">
        </div>
        {% endif %}
        <div class="p-6 sm:p-8">
          <div class="flex justify-between items-baseline gap-4 mb-3">
            <h3 class="text-xl sm:text-2xl font-bold" style="font-family: var(--font-heading);">{{ special.name }}</h3>
            <span class="text-xl font-bold text-primary flex-shrink-0">{{ special.price }}</span>
          </div>
          {% if special.description %}
          <p class="text-muted leading-relaxed">{{ special.description }}</p>
          {% endif %}
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
