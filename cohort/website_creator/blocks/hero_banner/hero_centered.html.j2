{# Hero: Centered. Big headline, subheadline, two CTA buttons.
   Tags: formal, conventional
   Variables: block.headline, block.subheadline, block.cta_primary_text, block.cta_primary_href,
              block.cta_secondary_text, block.cta_secondary_href
#}
<section class="bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-36 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight" style="font-family: var(--font-heading);">
      {{ block.headline }}
    </h1>
    {% if block.subheadline %}
    <p class="mt-6 text-lg sm:text-xl text-muted max-w-2xl mx-auto leading-relaxed">
      {{ block.subheadline }}
    </p>
    {% endif %}
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      {% if block.cta_primary_text %}
      <a href="{{ block.cta_primary_href | default('#') }}" class="btn-primary px-8 py-3 text-base font-semibold w-full sm:w-auto text-center">
        {{ block.cta_primary_text }}
      </a>
      {% endif %}
      {% if block.cta_secondary_text %}
      <a href="{{ block.cta_secondary_href | default('#') }}" class="btn-secondary px-8 py-3 text-base font-semibold w-full sm:w-auto text-center">
        {{ block.cta_secondary_text }}
      </a>
      {% endif %}
    </div>
  </div>
</section>
