{# Order Online: Heading with platform buttons and direct order button.
   Tags: bold, conventional
   Variables: block.heading, block.platforms [{name, url, logo}], block.direct_order_url
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    {% if block.heading %}
    <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="font-family: var(--font-heading);">{{ block.heading }}</h2>
    {% endif %}

    {% if block.direct_order_url %}
    <div class="mb-10">
      <a href="{{ block.direct_order_url }}" class="btn-primary inline-block px-10 py-4 text-lg font-semibold">
        Order Direct
      </a>
      <p class="mt-2 text-sm text-muted">Best prices -- order directly from us</p>
    </div>
    {% endif %}

    {% if block.platforms %}
    <div>
      <p class="text-sm text-muted mb-4">Also available on</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        {% for platform in block.platforms %}
        <a href="{{ platform.url }}" class="btn-secondary inline-flex items-center gap-3 px-6 py-3 text-base font-medium" aria-label="Order on {{ platform.name }}">
          {% if platform.logo %}
          <img src="{{ platform.logo }}" alt="" aria-hidden="true" class="w-6 h-6 object-contain">
          {% endif %}
          <span>{{ platform.name }}</span>
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>
</section>
