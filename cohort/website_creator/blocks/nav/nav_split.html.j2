{# Nav: Split layout with nav and CTA grouped on the right side. Logo left, everything else right.
   Tags: asymmetric, editorial
   Variables: block.product_name, block.logo, block.nav_items [{label, href}], block.cta_text, block.cta_href, block.secondary_cta_text, block.secondary_cta_href
#}
<header style="background: var(--color-bg);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      {# Logo / Brand #}
      <div class="flex-1 md:flex md:items-center md:gap-12">
        <a href="/" class="block" style="color: var(--color-primary);">
          <span class="sr-only">Home</span>
          {% if block.logo %}
          <img src="{{ block.logo }}" alt="{{ block.product_name }}" class="h-8 w-auto">
          {% else %}
          <span class="text-xl font-bold" style="font-family: var(--font-heading); color: var(--color-primary);">{{ block.product_name }}</span>
          {% endif %}
        </a>
      </div>

      {# Right side: nav + CTAs grouped together #}
      <div class="md:flex md:items-center md:gap-12">
        <nav aria-label="Global" class="hidden md:block">
          <ul class="flex items-center gap-6 text-sm">
            {% for item in block.nav_items %}
            <li>
              <a class="transition" style="color: var(--color-muted);" onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'" href="{{ item.href }}">{{ item.label }}</a>
            </li>
            {% endfor %}
          </ul>
        </nav>

        <div class="flex items-center gap-4">
          <div class="sm:flex sm:gap-4">
            {% if block.cta_text %}
            <a href="{{ block.cta_href | default('#') }}" class="btn-primary rounded-md px-5 py-2.5 text-sm font-medium text-white shadow-sm">
              {{ block.cta_text }}
            </a>
            {% endif %}

            {% if block.secondary_cta_text %}
            <div class="hidden sm:flex">
              <a href="{{ block.secondary_cta_href | default('#') }}" class="rounded-md px-5 py-2.5 text-sm font-medium" style="background: var(--color-accent); color: var(--color-primary);">
                {{ block.secondary_cta_text }}
              </a>
            </div>
            {% endif %}
          </div>

          {# Mobile hamburger #}
          <div class="block md:hidden">
            <button class="rounded-sm p-2 transition" style="background: var(--color-accent); color: var(--color-muted);" aria-controls="nav-split-mobile" onclick="document.getElementById('nav-split-mobile').classList.toggle('hidden')">
              <span class="sr-only">Toggle menu</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# Mobile menu #}
  <div id="nav-split-mobile" class="hidden md:hidden" style="border-top: 1px solid var(--color-border);">
    <div class="px-4 py-3 space-y-2">
      {% for item in block.nav_items %}
      <a href="{{ item.href }}" class="block px-3 py-2 text-base font-medium rounded-theme transition" style="color: var(--color-muted);">{{ item.label }}</a>
      {% endfor %}
      {% if block.cta_text %}
      <a href="{{ block.cta_href | default('#') }}" class="block mt-2 btn-primary text-center px-5 py-2.5 text-sm font-medium rounded-md">{{ block.cta_text }}</a>
      {% endif %}
    </div>
  </div>
</header>
