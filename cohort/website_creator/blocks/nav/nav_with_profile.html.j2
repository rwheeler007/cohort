{# Nav: Dashboard-style with user profile avatar and dropdown menu. Logo left, nav center-right, avatar far right.
   Tags: dashboard, app
   Variables: block.product_name, block.logo, block.nav_items [{label, href}], block.profile_items [{label, href}], block.profile_image
#}
<header style="background: var(--color-bg);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      {# Logo / Brand #}
      <div class="flex-1 md:flex md:items-center md:gap-12">
        <a href="/" class="block" style="color: var(--color-primary);">
          <span class="sr-only">Home</span>
          {% if block.logo %}
          <img src="{{ block.logo }}" alt="{{ block.product_name }}" class="h-8 w-auto">
          {% else %}
          <span class="text-xl font-bold" style="font-family: var(--font-heading); color: var(--color-primary);">{{ block.product_name }}</span>
          {% endif %}
        </a>
      </div>

      {# Right side: nav + profile #}
      <div class="md:flex md:items-center md:gap-12">
        <nav aria-label="Global" class="hidden md:block">
          <ul class="flex items-center gap-6 text-sm">
            {% for item in block.nav_items %}
            <li>
              <a class="transition" style="color: var(--color-muted);" onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'" href="{{ item.href }}">{{ item.label }}</a>
            </li>
            {% endfor %}
          </ul>
        </nav>

        <div class="flex items-center gap-4">
          {# Profile avatar + dropdown #}
          <div class="hidden md:relative md:block">
            <button type="button" class="overflow-hidden rounded-full shadow-inner" style="border: 1px solid var(--color-border);" onclick="this.nextElementSibling.classList.toggle('hidden')">
              <span class="sr-only">Toggle profile menu</span>
              {% if block.profile_image %}
              <img src="{{ block.profile_image }}" alt="" class="size-10 object-cover">
              {% else %}
              <div class="size-10 flex items-center justify-center text-sm font-bold" style="background: var(--color-accent); color: var(--color-primary);">
                <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              {% endif %}
            </button>

            <div class="hidden absolute end-0 z-10 mt-0.5 w-56 rounded-md shadow-lg" style="background: var(--color-bg); border: 1px solid var(--color-border);" role="menu">
              <div class="p-2">
                {% for item in block.profile_items %}
                <a href="{{ item.href }}" class="block rounded-lg px-4 py-2 text-sm transition" style="color: var(--color-muted);" role="menuitem">
                  {{ item.label }}
                </a>
                {% endfor %}
              </div>
            </div>
          </div>

          {# Mobile hamburger #}
          <div class="block md:hidden">
            <button class="rounded-sm p-2 transition" style="background: var(--color-accent); color: var(--color-muted);" aria-controls="nav-profile-mobile" onclick="document.getElementById('nav-profile-mobile').classList.toggle('hidden')">
              <span class="sr-only">Toggle menu</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# Mobile menu #}
  <div id="nav-profile-mobile" class="hidden md:hidden" style="border-top: 1px solid var(--color-border);">
    <div class="px-4 py-3 space-y-2">
      {% for item in block.nav_items %}
      <a href="{{ item.href }}" class="block px-3 py-2 text-base font-medium rounded-theme transition" style="color: var(--color-muted);">{{ item.label }}</a>
      {% endfor %}
      {% if block.profile_items %}
      <div class="pt-2 mt-2" style="border-top: 1px solid var(--color-border);">
        {% for item in block.profile_items %}
        <a href="{{ item.href }}" class="block px-3 py-2 text-sm" style="color: var(--color-muted);">{{ item.label }}</a>
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
</header>
