{# CTA Strip: Full-width primary color background, white text, heading + button.
   Tags: bold, conventional
   Variables: block.heading, block.subheading, block.cta_text, block.cta_href
#}
<section class="section-primary">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white" style="font-family: var(--font-heading);">{{ block.heading }}</h2>
    {% if block.subheading %}
    <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto leading-relaxed">{{ block.subheading }}</p>
    {% endif %}
    {% if block.cta_text %}
    <div class="mt-8">
      <a href="{{ block.cta_href | default('#') }}" class="inline-block px-8 py-3 text-base font-semibold bg-white rounded-theme hover:bg-gray-100 transition-colors" style="color: var(--color-primary);">
        {{ block.cta_text }}
      </a>
    </div>
    {% endif %}
  </div>
</section>
