{# FAQ: Accordion using HTML details/summary. Chevron rotates on open.
   Tags: conventional, minimal
   Variables: block.faqs [{question, answer}]
#}
<section class="bg-white py-16 sm:py-20 lg:py-24">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold text-center mb-12" style="font-family: var(--font-heading);">Frequently Asked Questions</h2>
    <div class="divide-y border-theme">
      {% for faq in block.faqs %}
      <details class="group py-4">
        <summary class="flex items-center justify-between cursor-pointer list-none text-left font-semibold text-gray-900 hover:text-primary transition-colors">
          <span>{{ faq.question }}</span>
          <svg class="w-5 h-5 flex-shrink-0 ml-4 text-muted transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="mt-3 text-muted leading-relaxed pr-12">
          {{ faq.answer }}
        </div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
