{# FAQ: Minimal accordion -- clean divider lines, no borders. Adapted from HyperUI (MIT).
   Tags: minimal, modern, lightweight
   Variables: block.faqs [{question, answer}]
#}
<section class="section-spacing">
  <div style="max-width: 48rem; margin: 0 auto; padding: 0 1rem;">
    <div style="display: flex; flex-direction: column;">
      {% for faq in block.faqs %}
      <details class="group" style="border-bottom: 1px solid #e5e7eb; padding: 1.25rem 0;"{% if loop.first %} open{% endif %}>
        <summary style="cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 1rem; font-weight: 600; font-size: 1.05rem; color: var(--color-text); list-style: none;">
          {{ faq.question }}
          <svg style="width: 1.25rem; height: 1.25rem; flex-shrink: 0; transition: transform 0.3s;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <p style="padding-top: 1rem; line-height: 1.7; color: var(--color-text); opacity: 0.8;">{{ faq.answer }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
<style>details[open] > summary svg { transform: rotate(180deg); }
details > summary::-webkit-details-marker { display: none; }</style>
