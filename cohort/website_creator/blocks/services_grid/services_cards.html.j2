{# Services: 3-column card grid. Icon, name, description, optional price range, CTA button.
   Tags: conventional, formal
   Variables: block.section_headline,
              block.services [{name, description, price_range, cta_text, cta_href, icon}]
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {% if block.section_headline %}
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold" style="font-family: var(--font-heading);">{{ block.section_headline }}</h2>
    </div>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for service in block.services %}
      <article class="bg-white border border-theme rounded-theme p-6 sm:p-8 flex flex-col">
        {# Icon #}
        <div class="w-14 h-14 flex items-center justify-center rounded-theme bg-alt mb-5">
          {% if service.icon %}
          <img src="{{ service.icon }}" alt="" aria-hidden="true" class="w-7 h-7">
          {% else %}
          <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          {% endif %}
        </div>

        {# Content #}
        <h3 class="text-lg font-semibold mb-2" style="font-family: var(--font-heading);">{{ service.name }}</h3>
        <p class="text-muted leading-relaxed mb-4 flex-1">{{ service.description }}</p>

        {% if service.price_range %}
        <p class="text-sm font-medium text-primary mb-4">{{ service.price_range }}</p>
        {% endif %}

        {% if service.cta_text %}
        <a href="{{ service.cta_href | default('#') }}" class="btn-primary inline-block px-6 py-2.5 text-sm font-semibold text-center mt-auto">
          {{ service.cta_text }}
        </a>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
</section>
