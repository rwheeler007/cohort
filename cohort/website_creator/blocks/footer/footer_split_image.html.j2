{# Footer: Image left panel, contact info + link columns + social on right.
   Adapted from HyperUI (MIT).
   Tags: creative, image, split
   Variables: block.product_name, block.image_url, block.phone_number, block.business_hours [],
              block.footer_columns [{title, links: [{label, href}]}],
              block.social_links [{platform, url}], block.copyright_text
#}
<footer style="background: var(--color-bg, #fff);" class="lg:grid lg:grid-cols-5">
  {# Image panel #}
  <div class="relative block h-32 lg:col-span-2 lg:h-full">
    {% if block.image_url %}
    <img
      src="{{ block.image_url }}"
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
    />
    {% else %}
    <div class="absolute inset-0 h-full w-full" style="background: var(--color-accent, #f3f4f6);"></div>
    {% endif %}
  </div>

  {# Content panel #}
  <div class="px-4 py-16 sm:px-6 lg:col-span-3 lg:px-8">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
      {# Contact info + social #}
      <div>
        {% if block.phone_number %}
        <p>
          <span class="text-xs tracking-wide uppercase" style="color: var(--color-text); opacity: 0.5;">Call us</span>

          <a
            href="tel:{{ block.phone_number }}"
            class="block text-2xl font-medium hover:opacity-75 sm:text-3xl"
            style="color: var(--color-text);"
          >
            {{ block.phone_number }}
          </a>
        </p>
        {% endif %}

        {% if block.business_hours %}
        <ul class="mt-8 space-y-1 text-sm" style="color: var(--color-text); opacity: 0.7;">
          {% for hours in block.business_hours %}
          <li>{{ hours }}</li>
          {% endfor %}
        </ul>
        {% endif %}

        {% if block.social_links %}
        <ul class="mt-8 flex gap-6">
          {% for social in block.social_links %}
          <li>
            <a
              href="{{ social.url }}"
              rel="noreferrer"
              target="_blank"
              class="transition hover:opacity-75"
              style="color: var(--color-text); opacity: 0.7;"
              aria-label="{{ social.platform }}"
            >
              <span class="text-sm">{{ social.platform }}</span>
            </a>
          </li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>

      {# Link columns #}
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        {% for col in block.footer_columns %}
        <div>
          <p class="font-medium" style="color: var(--color-text);">{{ col.title }}</p>

          <ul class="mt-6 space-y-4 text-sm">
            {% for link in col.links %}
            <li>
              <a href="{{ link.href }}" class="transition hover:opacity-75" style="color: var(--color-text); opacity: 0.7;">
                {{ link.label }}
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
    </div>

    {# Copyright bar #}
    <div class="mt-12 pt-12" style="border-top: 1px solid var(--color-border, #e5e7eb);">
      <div class="sm:flex sm:items-center sm:justify-between">
        {% set legal_links = [] %}
        {% for col in block.footer_columns %}
          {% for link in col.links %}
            {% if link.label in ['Terms & Conditions', 'Privacy Policy', 'Cookies'] %}
              {% if legal_links.append(link) %}{% endif %}
            {% endif %}
          {% endfor %}
        {% endfor %}
        {% if legal_links %}
        <ul class="flex flex-wrap gap-4 text-xs">
          {% for link in legal_links %}
          <li>
            <a href="{{ link.href }}" class="transition hover:opacity-75" style="color: var(--color-text); opacity: 0.5;">
              {{ link.label }}
            </a>
          </li>
          {% endfor %}
        </ul>
        {% endif %}

        <p class="mt-8 text-xs sm:mt-0" style="color: var(--color-text); opacity: 0.5;">
          {{ block.copyright_text | default('All rights reserved.') }}
        </p>
      </div>
    </div>
  </div>
</footer>
