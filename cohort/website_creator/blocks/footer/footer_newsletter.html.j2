{# Footer: Newsletter signup header, 5 link columns, social icon row, copyright bar.
   Adapted from HyperUI (MIT).
   Tags: dense, newsletter, conventional
   Variables: block.product_name, block.tagline, block.newsletter_heading,
              block.footer_columns [{title, links: [{label, href}]}],
              block.social_links [{platform, url}], block.copyright_text
#}
<footer style="background: var(--color-bg, #fff);">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="lg:flex lg:items-start lg:gap-8">
      {# Brand #}
      <div style="color: var(--color-primary);">
        <span class="text-2xl font-bold" style="font-family: var(--font-heading);">{{ block.product_name }}</span>
      </div>

      <div class="mt-8 grid grid-cols-2 gap-8 lg:mt-0 lg:grid-cols-5 lg:gap-y-16">
        {# Newsletter heading + tagline #}
        <div class="col-span-2">
          <div>
            <h2 class="text-2xl font-bold" style="color: var(--color-text);">
              {{ block.newsletter_heading | default('Get the latest news!') }}
            </h2>

            {% if block.tagline %}
            <p class="mt-4" style="color: var(--color-text); opacity: 0.6;">
              {{ block.tagline }}
            </p>
            {% endif %}
          </div>
        </div>

        {# Newsletter signup form #}
        <div class="col-span-2 lg:col-span-3 lg:flex lg:items-end">
          <form class="w-full" onsubmit="return false;">
            <label for="FooterEmail" class="sr-only">Email</label>

            <div
              class="p-2 sm:flex sm:items-center sm:gap-4"
              style="border: 1px solid var(--color-border, #e5e7eb);"
            >
              <input
                type="email"
                id="FooterEmail"
                placeholder="you@example.com"
                class="w-full border-none focus:border-transparent focus:ring-transparent sm:text-sm"
              />

              <button
                class="mt-1 w-full px-6 py-3 text-sm font-bold tracking-wide uppercase transition sm:mt-0 sm:w-auto sm:shrink-0"
                style="background: var(--color-primary); color: #fff;"
              >
                Sign Up
              </button>
            </div>
          </form>
        </div>

        {# Link columns #}
        {% for col in block.footer_columns %}
        <div class="col-span-2 sm:col-span-1">
          <p class="font-medium" style="color: var(--color-text);">{{ col.title }}</p>

          <ul class="mt-6 space-y-4 text-sm">
            {% for link in col.links %}
            <li>
              <a href="{{ link.href }}" class="transition hover:opacity-75" style="color: var(--color-text); opacity: 0.7;">
                {{ link.label }}
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}

        {# Social links row #}
        {% if block.social_links %}
        <ul class="col-span-2 flex justify-start gap-6 lg:col-span-5 lg:justify-end">
          {% for social in block.social_links %}
          <li>
            <a
              href="{{ social.url }}"
              rel="noreferrer"
              target="_blank"
              class="transition hover:opacity-75"
              style="color: var(--color-text); opacity: 0.7;"
              aria-label="{{ social.platform }}"
            >
              <span class="text-sm">{{ social.platform }}</span>
            </a>
          </li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
    </div>

    {# Copyright bar #}
    <div class="mt-8 pt-8" style="border-top: 1px solid var(--color-border, #e5e7eb);">
      <div class="sm:flex sm:justify-between">
        <p class="text-xs" style="color: var(--color-text); opacity: 0.5;">
          {{ block.copyright_text | default('All rights reserved.') }}
        </p>

        {% set all_links = [] %}
        {% for col in block.footer_columns %}
          {% for link in col.links %}
            {% if link.label in ['Terms & Conditions', 'Privacy Policy', 'Cookies'] %}
              {% if all_links.append(link) %}{% endif %}
            {% endif %}
          {% endfor %}
        {% endfor %}
        {% if all_links %}
        <ul class="mt-8 flex flex-wrap justify-start gap-4 text-xs sm:mt-0 lg:justify-end">
          {% for link in all_links %}
          <li>
            <a href="{{ link.href }}" class="transition hover:opacity-75" style="color: var(--color-text); opacity: 0.5;">
              {{ link.label }}
            </a>
          </li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
    </div>
  </div>
</footer>
