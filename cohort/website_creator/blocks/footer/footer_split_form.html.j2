{# Footer: Two-column split -- link columns left, newsletter/demo form right.
   Adapted from HyperUI (MIT).
   Tags: creative, split, newsletter, form
   Variables: block.product_name, block.tagline, block.form_heading, block.form_description,
              block.footer_columns [{title, links: [{label, href}]}],
              block.social_links [{platform, url}], block.copyright_text
#}
<footer style="background: var(--color-bg, #fff);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2">
      {# Right column: form (ordered first on mobile, last on desktop) #}
      <div
        class="border-b border-gray-100 py-8 lg:order-last lg:border-b-0 lg:border-s lg:py-16 lg:ps-16"
      >
        {# Mobile-only brand #}
        <div class="block lg:hidden" style="color: var(--color-primary);">
          <span class="text-xl font-bold" style="font-family: var(--font-heading);">{{ block.product_name }}</span>
        </div>

        <div class="mt-8 space-y-4 lg:mt-0">
          <span class="hidden h-1 w-10 rounded-sm lg:block" style="background: var(--color-primary);"></span>

          <div>
            <h2 class="text-2xl font-medium" style="color: var(--color-text);">
              {{ block.form_heading | default('Request a Demo') }}
            </h2>

            {% if block.form_description %}
            <p class="mt-4 max-w-lg" style="color: var(--color-text); opacity: 0.6;">
              {{ block.form_description }}
            </p>
            {% elif block.tagline %}
            <p class="mt-4 max-w-lg" style="color: var(--color-text); opacity: 0.6;">
              {{ block.tagline }}
            </p>
            {% endif %}
          </div>

          <form class="mt-6 w-full" onsubmit="return false;">
            <label for="SplitFormEmail" class="sr-only">Email</label>

            <div
              class="rounded-md p-2 sm:flex sm:items-center sm:gap-4"
              style="border: 1px solid var(--color-border, #e5e7eb);"
            >
              <input
                type="email"
                id="SplitFormEmail"
                placeholder="you@example.com"
                class="w-full border-none focus:border-transparent focus:ring-transparent sm:text-sm"
              />

              <button
                class="mt-1 w-full rounded-sm px-6 py-3 text-sm font-bold tracking-wide uppercase transition sm:mt-0 sm:w-auto sm:shrink-0"
                style="background: var(--color-primary); color: #fff;"
              >
                Sign Up
              </button>
            </div>
          </form>
        </div>
      </div>

      {# Left column: brand + link columns #}
      <div class="py-8 lg:py-16 lg:pe-16">
        {# Desktop-only brand #}
        <div class="hidden lg:block" style="color: var(--color-primary);">
          <span class="text-xl font-bold" style="font-family: var(--font-heading);">{{ block.product_name }}</span>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-8 sm:grid-cols-3">
          {% for col in block.footer_columns %}
          <div>
            <p class="font-medium" style="color: var(--color-text);">{{ col.title }}</p>

            <ul class="mt-6 space-y-4 text-sm">
              {% for link in col.links %}
              <li>
                <a href="{{ link.href }}" class="transition hover:opacity-75" style="color: var(--color-text); opacity: 0.7;">
                  {{ link.label }}
                </a>
              </li>
              {% endfor %}
            </ul>
          </div>
          {% endfor %}
        </div>

        {# Social links #}
        {% if block.social_links %}
        <ul class="mt-8 flex gap-6">
          {% for social in block.social_links %}
          <li>
            <a
              href="{{ social.url }}"
              rel="noreferrer"
              target="_blank"
              class="transition hover:opacity-75"
              style="color: var(--color-text); opacity: 0.7;"
              aria-label="{{ social.platform }}"
            >
              <span class="text-sm">{{ social.platform }}</span>
            </a>
          </li>
          {% endfor %}
        </ul>
        {% endif %}

        {# Copyright #}
        <p class="mt-8 text-xs" style="color: var(--color-text); opacity: 0.5;">
          {{ block.copyright_text | default('All rights reserved.') }}
        </p>
      </div>
    </div>
  </div>
</footer>
