{# Footer: Logo, 4 link columns, social icons, copyright.
   Tags: conventional, dense
   Variables: block.product_name, block.tagline, block.footer_columns [{title, links: [{label, href}]}],
              block.social_links [{platform, url}], block.copyright_text
#}
<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-2 md:grid-cols-6 gap-8">
      {# Brand column #}
      <div class="col-span-2">
        <div class="text-xl font-bold text-white" style="font-family: var(--font-heading);">{{ block.product_name }}</div>
        {% if block.tagline %}
        <p class="mt-3 text-sm text-gray-400 leading-relaxed max-w-xs">{{ block.tagline }}</p>
        {% endif %}
        {% if block.social_links %}
        <div class="mt-6 flex gap-4">
          {% for link in block.social_links %}
          <a href="{{ link.url }}" class="text-gray-400 hover:text-white transition-colors" aria-label="{{ link.platform }}">
            <span class="text-sm">{{ link.platform }}</span>
          </a>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      {# Link columns #}
      {% for col in block.footer_columns %}
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider">{{ col.title }}</h3>
        <ul class="mt-4 space-y-3">
          {% for link in col.links %}
          <li><a href="{{ link.href }}" class="text-sm text-gray-400 hover:text-white transition-colors">{{ link.label }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>

    {# Copyright #}
    {% if block.copyright_text %}
    <div class="mt-12 pt-8 border-t border-gray-700 text-sm text-gray-500 text-center">
      {{ block.copyright_text }}
    </div>
    {% endif %}
  </div>
</footer>
