{# Footer: Centered newsletter pill input, tagline + social, 3-column link grid, copyright.
   Adapted from HyperUI (MIT).
   Tags: creative, centered, newsletter
   Variables: block.product_name, block.tagline, block.newsletter_heading,
              block.footer_columns [{title, links: [{label, href}]}],
              block.social_links [{platform, url}], block.copyright_text
#}
<footer style="background: var(--color-bg, #fff);">
  <div class="mx-auto max-w-7xl px-4 pt-16 pb-8 sm:px-6 lg:px-8">
    {# Centered newsletter #}
    <div class="mx-auto max-w-md">
      <strong class="block text-center text-xl font-bold sm:text-3xl" style="color: var(--color-text);">
        {{ block.newsletter_heading | default('Stay in the loop') }}
      </strong>

      <form class="mt-6" onsubmit="return false;">
        <div class="relative max-w-lg">
          <label class="sr-only" for="CenteredNewsletterEmail">Email</label>

          <input
            class="w-full rounded-full p-4 pe-32 text-sm font-medium"
            style="background: var(--color-accent, #f3f4f6); border: 1px solid var(--color-border, #e5e7eb);"
            id="CenteredNewsletterEmail"
            type="email"
            placeholder="you@example.com"
          />

          <button
            class="absolute end-1 top-1/2 -translate-y-1/2 rounded-full px-5 py-3 text-sm font-medium text-white transition hover:opacity-90"
            style="background: var(--color-primary);"
          >
            Subscribe
          </button>
        </div>
      </form>
    </div>

    {# Two-column: tagline+social left, link columns right #}
    <div class="mt-16 grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-32">
      <div class="mx-auto max-w-sm lg:max-w-none">
        {% if block.tagline %}
        <p class="mt-4 text-center lg:text-left lg:text-lg" style="color: var(--color-text); opacity: 0.6;">
          {{ block.tagline }}
        </p>
        {% endif %}

        {% if block.social_links %}
        <div class="mt-6 flex justify-center gap-4 lg:justify-start">
          {% for social in block.social_links %}
          <a
            href="{{ social.url }}"
            target="_blank"
            rel="noreferrer"
            class="transition hover:opacity-75"
            style="color: var(--color-text); opacity: 0.7;"
            aria-label="{{ social.platform }}"
          >
            <span class="text-sm">{{ social.platform }}</span>
          </a>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      {# Link columns #}
      <div class="grid grid-cols-1 gap-8 text-center lg:grid-cols-3 lg:text-left">
        {% for col in block.footer_columns %}
        <div>
          <strong class="font-medium" style="color: var(--color-text);">{{ col.title }}</strong>

          <ul class="mt-6 space-y-1">
            {% for link in col.links %}
            <li>
              <a href="{{ link.href }}" class="transition hover:opacity-75" style="color: var(--color-text); opacity: 0.7;">
                {{ link.label }}
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
    </div>

    {# Copyright #}
    <div class="mt-16 pt-8" style="border-top: 1px solid var(--color-border, #e5e7eb);">
      <p class="text-center text-xs leading-relaxed" style="color: var(--color-text); opacity: 0.5;">
        {{ block.copyright_text | default('All rights reserved.') }}
      </p>
    </div>
  </div>
</footer>
