{# Location: Map embed with address and directions info.
   Tags: warm, formal
   Variables: block.address, block.map_embed_url, block.directions_text
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-12">
      {# Map #}
      <div class="lg:col-span-3">
        {% if block.map_embed_url %}
        <div class="rounded-theme overflow-hidden border border-theme aspect-video">
          <iframe
            src="{{ block.map_embed_url }}"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Map showing restaurant location"
          ></iframe>
        </div>
        {% endif %}
      </div>

      {# Info #}
      <div class="lg:col-span-2 flex flex-col justify-center">
        <h2 class="text-2xl sm:text-3xl font-bold mb-6" style="font-family: var(--font-heading);">Find Us</h2>

        {% if block.address %}
        <div class="flex items-start gap-3 mb-6">
          <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <address class="not-italic text-muted leading-relaxed">{{ block.address }}</address>
        </div>
        {% endif %}

        {% if block.directions_text %}
        <div>
          <h3 class="text-lg font-semibold mb-2" style="font-family: var(--font-heading);">Directions</h3>
          <p class="text-muted leading-relaxed">{{ block.directions_text }}</p>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
