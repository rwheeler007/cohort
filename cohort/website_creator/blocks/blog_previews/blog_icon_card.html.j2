{# Blog Previews: Icon-badged cards with title, excerpt, and arrow link. No images.
   Tags: modern, icon-driven
   Variables: block.posts [{title, excerpt, href, icon_svg}]
   - icon_svg: optional inline SVG string for the icon badge; defaults to a generic document icon
#}
<section class="section-spacing py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for post in block.posts %}
      <article
        class="rounded-lg border p-4 shadow-sm transition hover:shadow-lg sm:p-6"
        style="background: var(--color-surface, #fff); border-color: var(--color-border, #e5e7eb);"
      >
        <span class="inline-block rounded-sm p-2 text-white" style="background: var(--color-primary);">
          {% if post.icon_svg %}
            {{ post.icon_svg | safe }}
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 14l9-5-9-5-9 5 9 5z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
            </svg>
          {% endif %}
        </span>

        <a href="{{ post.href | default('#') }}">
          <h3 class="mt-0.5 text-lg font-medium" style="color: var(--color-text); font-family: var(--font-heading);">
            {{ post.title }}
          </h3>
        </a>

        {% if post.excerpt %}
        <p class="mt-2 line-clamp-3 text-sm leading-relaxed" style="color: var(--color-text-muted);">
          {{ post.excerpt }}
        </p>
        {% endif %}

        <a
          href="{{ post.href | default('#') }}"
          class="btn-primary group mt-4 inline-flex items-center gap-1 text-sm font-medium"
          style="color: var(--color-primary);"
        >
          Find out more
          <span aria-hidden="true" class="block transition-all group-hover:ms-0.5">&rarr;</span>
        </a>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
