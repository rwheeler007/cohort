{# Blog Previews: 3-column article card grid.
   Tags: conventional, dense
   Variables: block.posts [{image, date, title, excerpt, href}]
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for post in block.posts %}
      <article class="bg-white border border-theme rounded-theme overflow-hidden flex flex-col">
        {# Image #}
        {% if post.image %}
        <a href="{{ post.href | default('#') }}" class="block aspect-[16/9] overflow-hidden">
          <img src="{{ post.image }}" alt="{{ post.title }}" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy">
        </a>
        {% else %}
        <div class="aspect-[16/9] bg-alt flex items-center justify-center">
          <span class="text-muted text-sm">Article image</span>
        </div>
        {% endif %}

        {# Content #}
        <div class="p-6 flex flex-col flex-1">
          {% if post.date %}
          <time class="text-xs text-muted uppercase tracking-wider">{{ post.date }}</time>
          {% endif %}
          <h3 class="mt-2 text-lg font-semibold leading-snug" style="font-family: var(--font-heading);">
            <a href="{{ post.href | default('#') }}" class="hover:text-primary transition-colors">{{ post.title }}</a>
          </h3>
          {% if post.excerpt %}
          <p class="mt-2 text-sm text-muted leading-relaxed flex-1">{{ post.excerpt }}</p>
          {% endif %}
          <a href="{{ post.href | default('#') }}" class="mt-4 text-sm font-semibold text-primary hover:underline inline-block">Read more</a>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
