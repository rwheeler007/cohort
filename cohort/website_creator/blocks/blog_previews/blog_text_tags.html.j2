{# Blog Previews: Text-only cards with date, title, and category tags. No images.
   Tags: minimal, text-focused
   Variables: block.posts [{date, title, href, category, tags}]
   - tags: optional list of tag strings displayed as badges
   - category: fallback single category if tags not provided
#}
<section class="section-spacing py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for post in block.posts %}
      <article class="rounded-[10px] border px-4 pt-12 pb-4" style="background: var(--color-surface, #fff); border-color: var(--color-border, #e5e7eb);">
        {% if post.date %}
        <time class="block text-xs" style="color: var(--color-text-muted);">{{ post.date }}</time>
        {% endif %}

        <a href="{{ post.href | default('#') }}">
          <h3 class="mt-0.5 text-lg font-medium" style="color: var(--color-text); font-family: var(--font-heading);">
            {{ post.title }}
          </h3>
        </a>

        {% if post.tags or post.category %}
        <div class="mt-4 flex flex-wrap gap-1">
          {% if post.tags %}
            {% for tag in post.tags %}
            <span
              class="rounded-full px-2.5 py-0.5 text-xs whitespace-nowrap"
              style="background: var(--color-accent-light, #f3e8ff); color: var(--color-primary);"
            >
              {{ tag }}
            </span>
            {% endfor %}
          {% elif post.category %}
            <span
              class="rounded-full px-2.5 py-0.5 text-xs whitespace-nowrap"
              style="background: var(--color-accent-light, #f3e8ff); color: var(--color-primary);"
            >
              {{ post.category }}
            </span>
          {% endif %}
        </div>
        {% endif %}
      </article>
      {% endfor %}
    </div>
  </div>
</section>
