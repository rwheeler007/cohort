{# Blog Previews: Image-top card with title, excerpt, and arrow link CTA.
   Tags: conventional, actionable
   Variables: block.posts [{image, title, excerpt, href}]
#}
<section class="section-spacing py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for post in block.posts %}
      <article class="overflow-hidden rounded-lg border bg-white shadow-sm" style="background: var(--color-surface, #fff); border-color: var(--color-border, #e5e7eb);">
        {% if post.image %}
        <a href="{{ post.href | default('#') }}" class="block">
          <img
            src="{{ post.image }}"
            alt="{{ post.title }}"
            class="h-56 w-full object-cover"
            loading="lazy"
          />
        </a>
        {% else %}
        <div class="h-56 w-full flex items-center justify-center" style="background: var(--color-accent-light, #f3f4f6);">
          <span class="text-sm" style="color: var(--color-text-muted);">Article image</span>
        </div>
        {% endif %}

        <div class="p-4 sm:p-6">
          <a href="{{ post.href | default('#') }}">
            <h3 class="text-lg font-medium" style="color: var(--color-text); font-family: var(--font-heading);">
              {{ post.title }}
            </h3>
          </a>

          {% if post.excerpt %}
          <p class="mt-2 line-clamp-3 text-sm leading-relaxed" style="color: var(--color-text-muted);">
            {{ post.excerpt }}
          </p>
          {% endif %}

          <a
            href="{{ post.href | default('#') }}"
            class="btn-primary group mt-4 inline-flex items-center gap-1 text-sm font-medium"
            style="color: var(--color-primary);"
          >
            Find out more
            <span aria-hidden="true" class="block transition-all group-hover:ms-0.5">&rarr;</span>
          </a>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
