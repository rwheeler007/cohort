{# Blog Previews: Image-top card with date, title, and excerpt. Shadow hover effect.
   Tags: conventional, clean
   Variables: block.posts [{image, date, title, excerpt, href}]
#}
<section class="section-spacing py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for post in block.posts %}
      <article class="overflow-hidden rounded-lg shadow-sm transition hover:shadow-lg" style="background: var(--color-surface, #fff);">
        {% if post.image %}
        <a href="{{ post.href | default('#') }}" class="block">
          <img
            src="{{ post.image }}"
            alt="{{ post.title }}"
            class="h-56 w-full object-cover"
            loading="lazy"
          />
        </a>
        {% else %}
        <div class="h-56 w-full flex items-center justify-center" style="background: var(--color-accent-light, #f3f4f6);">
          <span class="text-sm" style="color: var(--color-text-muted);">Article image</span>
        </div>
        {% endif %}

        <div class="p-4 sm:p-6">
          {% if post.date %}
          <time class="block text-xs" style="color: var(--color-text-muted);">{{ post.date }}</time>
          {% endif %}

          <a href="{{ post.href | default('#') }}">
            <h3 class="mt-0.5 text-lg" style="color: var(--color-text); font-family: var(--font-heading);">
              {{ post.title }}
            </h3>
          </a>

          {% if post.excerpt %}
          <p class="mt-2 line-clamp-3 text-sm leading-relaxed" style="color: var(--color-text-muted);">
            {{ post.excerpt }}
          </p>
          {% endif %}
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
