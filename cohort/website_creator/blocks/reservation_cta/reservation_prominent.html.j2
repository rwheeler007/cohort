{# Reservation: Prominent booking section with primary-color background, phone, button, hours.
   Tags: bold, warm
   Variables: block.heading, block.description, block.booking_url, block.phone,
              block.hours [{day, open, close}]
#}
<section class="section-primary py-16 sm:py-20 lg:py-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    {% if block.heading %}
    <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="font-family: var(--font-heading);">{{ block.heading }}</h2>
    {% endif %}
    {% if block.description %}
    <p class="text-lg opacity-90 max-w-2xl mx-auto mb-8 leading-relaxed">{{ block.description }}</p>
    {% endif %}

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      {% if block.booking_url %}
      <a href="{{ block.booking_url }}" class="inline-block bg-white font-semibold px-8 py-3 rounded-theme transition-colors hover:bg-gray-100" style="color: var(--color-primary);">
        Reserve a Table
      </a>
      {% endif %}
      {% if block.phone %}
      <a href="tel:{{ block.phone }}" class="inline-block border-2 border-white px-8 py-3 rounded-theme font-semibold transition-colors hover:bg-white/10" aria-label="Call us at {{ block.phone }}">
        {{ block.phone }}
      </a>
      {% endif %}
    </div>

    {% if block.hours %}
    <div class="max-w-md mx-auto">
      <h3 class="text-lg font-semibold mb-4" style="font-family: var(--font-heading);">
        <span class="sr-only">Opening </span>Hours
      </h3>
      <table class="w-full text-left">
        <caption class="sr-only">Restaurant opening hours</caption>
        <thead class="sr-only">
          <tr><th>Day</th><th>Hours</th></tr>
        </thead>
        <tbody>
          {% for row in block.hours %}
          <tr class="border-b border-white/20">
            <td class="py-2 font-medium">{{ row.day }}</td>
            <td class="py-2 text-right opacity-90">
              {% if row.open and row.close %}
              {{ row.open }} &ndash; {{ row.close }}
              {% else %}
              Closed
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
  </div>
</section>
