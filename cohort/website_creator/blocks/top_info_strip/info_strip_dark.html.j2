{# Top Info Strip: Dark background with phone, email, hours, address.
   Tags: formal, bold
   Variables: block.phone, block.email, block.hours_text, block.address
#}
<div class="bg-secondary text-white text-sm" role="complementary" aria-label="Contact information">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 flex flex-wrap items-center justify-between gap-x-6 gap-y-1">
    {% if block.phone %}
    <a href="tel:{{ block.phone }}" class="inline-flex items-center gap-1.5 text-white/90 hover:text-white transition-colors">
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
      </svg>
      <span>{{ block.phone }}</span>
    </a>
    {% endif %}
    {% if block.email %}
    <a href="mailto:{{ block.email }}" class="inline-flex items-center gap-1.5 text-white/90 hover:text-white transition-colors">
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      <span>{{ block.email }}</span>
    </a>
    {% endif %}
    {% if block.hours_text %}
    <span class="inline-flex items-center gap-1.5 text-white/90">
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span>{{ block.hours_text }}</span>
    </span>
    {% endif %}
    {% if block.address %}
    <span class="inline-flex items-center gap-1.5 text-white/90">
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <span>{{ block.address }}</span>
    </span>
    {% endif %}
  </div>
</div>
