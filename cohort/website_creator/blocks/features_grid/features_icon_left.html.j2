{# Features: Icon on left, text on right. No card border, minimal style.
   Tags: minimal, modern
   Variables: block.section_headline, block.section_description,
              block.features [{icon, title, description}]
#}
<section class="bg-white py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Section header #}
    {% if block.section_headline %}
    <div class="max-w-3xl mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold" style="font-family: var(--font-heading);">{{ block.section_headline }}</h2>
      {% if block.section_description %}
      <p class="mt-4 text-lg text-muted leading-relaxed">{{ block.section_description }}</p>
      {% endif %}
    </div>
    {% endif %}

    {# Feature rows #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
      {% for feature in block.features %}
      <div class="flex gap-5">
        {# Icon #}
        <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-alt">
          {% if feature.icon %}
          <img src="{{ feature.icon }}" alt="" aria-hidden="true" class="w-5 h-5">
          {% else %}
          <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          {% endif %}
        </div>
        {# Text #}
        <div>
          <h3 class="text-base font-semibold mb-1" style="font-family: var(--font-heading);">{{ feature.title }}</h3>
          <p class="text-muted leading-relaxed text-sm">{{ feature.description }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
