{# Features: 2-column wide cards -- larger feature cards in 2-col grid. Good for 4-6 features.
   Tags: spacious, premium, service-focused
   Variables: block.section_headline, block.section_subheadline, block.features [{title, description, icon}]
#}
<section class="section-spacing">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {% if block.section_headline %}
    <div style="max-width: 32rem; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 1.75rem; font-weight: 700; font-family: var(--font-heading); color: var(--color-text);">{{ block.section_headline }}</h2>
      {% if block.section_subheadline %}
      <p style="margin-top: 1rem; font-size: 1.1rem; color: var(--color-text); opacity: 0.7;">{{ block.section_subheadline }}</p>
      {% endif %}
    </div>
    {% endif %}

    <div style="margin-top: 2rem; display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
      {% for feature in block.features %}
      <div style="border-radius: var(--radius); background: var(--color-accent); padding: 2rem; display: flex; gap: 1.25rem; align-items: flex-start;">
        {% if feature.icon %}
        <div style="flex-shrink: 0; width: 3rem; height: 3rem; border-radius: 50%; background: var(--color-primary); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; font-weight: 700;">
          {{ feature.icon | default(loop.index) }}
        </div>
        {% endif %}
        <div>
          <h3 style="font-size: 1.1rem; font-weight: 600; color: var(--color-text); font-family: var(--font-heading);">{{ feature.title }}</h3>
          <p style="margin-top: 0.5rem; line-height: 1.7; color: var(--color-text); opacity: 0.75;">{{ feature.description }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
