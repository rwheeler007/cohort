{# Features: 4-column centered icons -- centered icon above title and short description.
   Adapted from HyperUI feature-grids/3 (MIT).
   Tags: clean, minimal, icon-centered
   Variables: block.section_headline, block.section_description,
              block.features [{icon, title, description}]
#}
<section class="section-spacing">
  <div style="max-width: 72rem; margin: 0 auto; padding: 0 1rem;">
    {% if block.section_headline %}
    <div style="text-align: center; max-width: 48rem; margin: 0 auto 3rem;">
      <h2 style="font-family: var(--font-heading); font-size: 1.875rem; font-weight: 700;">{{ block.section_headline }}</h2>
      {% if block.section_description %}
      <p style="margin-top: 1rem; color: var(--color-text); opacity: 0.7; font-size: 1rem; line-height: 1.7;">{{ block.section_description }}</p>
      {% endif %}
    </div>
    {% endif %}

    <div style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
      {% for feature in block.features %}
      <div style="text-align: center;">
        <div style="display: inline-flex; padding: 0.75rem; border-radius: var(--radius); background: var(--color-accent);">
          {% if feature.icon %}
          <img src="{{ feature.icon }}" alt="" aria-hidden="true" style="width: 1.5rem; height: 1.5rem;">
          {% else %}
          <svg style="width: 1.5rem; height: 1.5rem; color: var(--color-text); opacity: 0.7;" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
          </svg>
          {% endif %}
        </div>
        <h3 style="margin-top: 1rem; font-family: var(--font-heading); font-size: 1.1rem; font-weight: 600; color: var(--color-text);">{{ feature.title }}</h3>
        {% if feature.description %}
        <p style="margin-top: 0.5rem; color: var(--color-text); opacity: 0.7; line-height: 1.6;">{{ feature.description }}</p>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>
<style>
@media (min-width: 640px) {
  .section-spacing > div > div:last-child { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1024px) {
  .section-spacing > div > div:last-child { grid-template-columns: repeat(4, 1fr); }
}
</style>
