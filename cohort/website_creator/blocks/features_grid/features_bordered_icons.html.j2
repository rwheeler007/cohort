{# Features: Bordered icon cards -- bordered cards with icon badge. Adapted from HyperUI (MIT).
   Tags: professional, structured, corporate
   Variables: block.section_headline, block.section_subheadline, block.features [{title, description, icon}]
#}
<section class="section-spacing">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {% if block.section_headline %}
    <div style="max-width: 32rem; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 1.75rem; font-weight: 700; font-family: var(--font-heading); color: var(--color-text); line-height: 1.2;">{{ block.section_headline }}</h2>
      {% if block.section_subheadline %}
      <p style="margin-top: 1rem; font-size: 1.1rem; color: var(--color-text); opacity: 0.7; line-height: 1.7;">{{ block.section_subheadline }}</p>
      {% endif %}
    </div>
    {% endif %}

    <div style="margin-top: 2rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
      {% for feature in block.features %}
      <div style="border-radius: var(--radius); border: 1px solid #e5e7eb; padding: 1.5rem;">
        {% if feature.icon %}
        <div style="display: inline-flex; border-radius: var(--radius); background: var(--color-accent); padding: 0.75rem; color: var(--color-primary);">
          <span style="font-size: 1.25rem;">{{ feature.icon }}</span>
        </div>
        {% endif %}

        <h3 style="margin-top: 1rem; font-size: 1.1rem; font-weight: 600; color: var(--color-text); font-family: var(--font-heading);">{{ feature.title }}</h3>
        <p style="margin-top: 0.5rem; line-height: 1.7; color: var(--color-text); opacity: 0.75;">{{ feature.description }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
