{# Features: 3-column card grid with icon, title, description. Bordered cards.
   Tags: conventional, formal
   Variables: block.section_headline, block.section_description,
              block.features [{icon, title, description}]
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Section header #}
    {% if block.section_headline %}
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold" style="font-family: var(--font-heading);">{{ block.section_headline }}</h2>
      {% if block.section_description %}
      <p class="mt-4 text-lg text-muted leading-relaxed">{{ block.section_description }}</p>
      {% endif %}
    </div>
    {% endif %}

    {# Cards grid #}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for feature in block.features %}
      <div class="bg-white border border-theme rounded-theme p-6 sm:p-8">
        {# Icon placeholder #}
        <div class="w-12 h-12 flex items-center justify-center rounded-theme bg-alt mb-5">
          {% if feature.icon %}
          <img src="{{ feature.icon }}" alt="" aria-hidden="true" class="w-6 h-6">
          {% else %}
          <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          {% endif %}
        </div>
        <h3 class="text-lg font-semibold mb-2" style="font-family: var(--font-heading);">{{ feature.title }}</h3>
        <p class="text-muted leading-relaxed">{{ feature.description }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
