{# Stats Banner: 4-column grid of stat cards with large numbers. Bordered cards.
   Tags: conventional, dense
   Variables: block.section_headline, block.section_description,
              block.stats [{value, label}]
#}
<section class="section-alt py-16 sm:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {% if block.section_headline %}
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold" style="font-family: var(--font-heading);">{{ block.section_headline }}</h2>
      {% if block.section_description %}
      <p class="mt-4 text-lg text-muted leading-relaxed">{{ block.section_description }}</p>
      {% endif %}
    </div>
    {% endif %}

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
      {% for stat in block.stats %}
      <div class="bg-white border border-theme rounded-theme p-6 text-center">
        <div class="text-3xl sm:text-4xl font-bold text-primary" style="font-family: var(--font-heading);">{{ stat.value }}</div>
        <div class="mt-2 text-sm text-muted">{{ stat.label }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
