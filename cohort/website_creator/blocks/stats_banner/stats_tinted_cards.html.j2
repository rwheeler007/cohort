{# Stats: Tinted card grid -- value + label on brand-tinted backgrounds. Adapted from HyperUI (MIT).
   Tags: warm, branded, inviting
   Variables: block.heading, block.subheading, block.stats [{value, label}]
#}
<section class="section-spacing">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {% if block.heading %}
    <div style="max-width: 48rem; margin: 0 auto; text-align: center;">
      <h2 style="font-size: 1.75rem; font-weight: 700; font-family: var(--font-heading); color: var(--color-text);">{{ block.heading }}</h2>
      {% if block.subheading %}
      <p style="margin-top: 1rem; color: var(--color-text); opacity: 0.7; font-size: 1.1rem;">{{ block.subheading }}</p>
      {% endif %}
    </div>
    {% endif %}

    <div style="margin-top: 2rem; display: grid; grid-template-columns: repeat({{ block.stats | length | default(4) }}, 1fr); gap: 1rem;">
      {% for stat in block.stats %}
      <div style="display: flex; flex-direction: column; border-radius: var(--radius); background: var(--color-accent); padding: 1.5rem 1rem; text-align: center;">
        <span style="font-size: 2.5rem; font-weight: 800; color: var(--color-primary);">{{ stat.value }}</span>
        <span style="font-size: 1rem; font-weight: 500; color: var(--color-text); opacity: 0.7; margin-top: 0.5rem;">{{ stat.label }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
