{# Contact: Form on left, contact info on right.
   Tags: conventional, formal
   Variables: block.form_fields [{type, label, name, required}],
              block.email, block.phone, block.address, block.social_links
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      {# Form #}
      <div>
        <h2 class="text-3xl font-bold mb-8" style="font-family: var(--font-heading);">Get in Touch</h2>
        <form action="{{ block.form_action | default('mailto:' ~ block.email if block.email else '#') }}" method="POST"{% if not block.form_action and block.email %} enctype="text/plain"{% endif %}{% if block.form_action %} data-form-handler="{{ block.form_action }}"{% endif %} class="space-y-6">
          {% for field in block.form_fields %}
          <div>
            <label for="field-{{ field.name }}" class="block text-sm font-medium text-gray-700 mb-1">
              {{ field.label }}{% if field.required %} <span class="text-red-500" aria-hidden="true">*</span>{% endif %}
            </label>
            {% if field.type == 'textarea' %}
            <textarea id="field-{{ field.name }}" name="{{ field.name }}" rows="4"{% if field.required %} required{% endif %} class="w-full px-4 py-2 border border-theme rounded-theme focus:outline-none focus:ring-2 focus:ring-offset-0" style="--tw-ring-color: var(--color-primary);"></textarea>
            {% else %}
            <input type="{{ field.type | default('text') }}" id="field-{{ field.name }}" name="{{ field.name }}"{% if field.required %} required{% endif %} class="w-full px-4 py-2 border border-theme rounded-theme focus:outline-none focus:ring-2 focus:ring-offset-0" style="--tw-ring-color: var(--color-primary);">
            {% endif %}
          </div>
          {% endfor %}
          <button type="submit" class="btn-primary px-8 py-3 text-base font-semibold">Send Message</button>
        </form>
      </div>

      {# Contact info #}
      <div class="lg:pl-8">
        <h2 class="text-3xl font-bold mb-8" style="font-family: var(--font-heading);">Contact Info</h2>
        <div class="space-y-6">
          {% if block.email %}
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <div>
              <div class="text-sm font-medium text-gray-700">Email</div>
              <a href="mailto:{{ block.email }}" class="text-primary hover:underline">{{ block.email }}</a>
            </div>
          </div>
          {% endif %}

          {% if block.phone %}
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <div>
              <div class="text-sm font-medium text-gray-700">Phone</div>
              <a href="tel:{{ block.phone }}" class="text-primary hover:underline">{{ block.phone }}</a>
            </div>
          </div>
          {% endif %}

          {% if block.address %}
          <div class="flex items-start gap-4">
            <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div>
              <div class="text-sm font-medium text-gray-700">Address</div>
              <div class="text-muted">{{ block.address }}</div>
            </div>
          </div>
          {% endif %}

          {% if block.social_links %}
          <div class="pt-4">
            <div class="text-sm font-medium text-gray-700 mb-3">Follow Us</div>
            <div class="flex gap-4">
              {% for link in block.social_links %}
              <a href="{{ link.url }}" class="text-muted hover:text-primary transition-colors" aria-label="{{ link.platform }}">
                <span class="text-sm font-medium">{{ link.platform }}</span>
              </a>
              {% endfor %}
            </div>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>
