{# Contact: Centered card form with dropdown select fields for subject/priority.
   Adapted from HyperUI (MIT).
   Tags: dropdowns, categorized, support
   Variables: block.heading, block.subheading, block.form_action, block.cta_text,
              block.form_fields [{type, label, name, required, placeholder, options [{value, text}]}],
              block.select_fields [{label, name, required, options [{value, text}]}]
#}
<section class="section-spacing" style="padding: 4rem 1.5rem;">
  <form
    action="{{ block.form_action | default('#') }}"
    method="POST"
    {% if block.form_action %} data-form-handler="{{ block.form_action }}"{% endif %}
    style="max-width: 28rem; margin: 0 auto; display: flex; flex-direction: column; gap: 1rem; border-radius: 0.5rem; border: 1px solid var(--color-border, #d1d5db); padding: 1.5rem; background: var(--color-accent);"
  >
    {% if block.heading %}
    <h2 style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin: 0 0 0.25rem 0;">
      {{ block.heading | default('Contact Support') }}
    </h2>
    {% endif %}

    {% if block.subheading %}
    <p style="font-size: 0.875rem; color: var(--color-muted, #6b7280); margin: 0 0 0.5rem 0;">
      {{ block.subheading }}
    </p>
    {% endif %}

    {% for field in block.form_fields %}
    <div>
      <label
        for="field-{{ field.name }}"
        style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--color-text); margin-bottom: 0.25rem;"
      >
        {{ field.label }}{% if field.required %} <span style="color: var(--color-danger, #ef4444);" aria-hidden="true">*</span>{% endif %}
      </label>

      {% if field.type == 'textarea' %}
      <textarea
        id="field-{{ field.name }}"
        name="{{ field.name }}"
        rows="4"
        {% if field.placeholder %}placeholder="{{ field.placeholder }}"{% endif %}
        {% if field.required %}required{% endif %}
        style="margin-top: 0.25rem; width: 100%; resize: none; border-radius: 0.5rem; border: 1px solid var(--color-border, #d1d5db); padding: 0.5rem 0.75rem; outline: none;"
      ></textarea>
      {% elif field.type == 'select' %}
      <select
        id="field-{{ field.name }}"
        name="{{ field.name }}"
        {% if field.required %}required{% endif %}
        style="margin-top: 0.25rem; width: 100%; border-radius: 0.5rem; border: 1px solid var(--color-border, #d1d5db); padding: 0.5rem 0.75rem; outline: none; background: white;"
      >
        {% if field.placeholder %}
        <option value="">{{ field.placeholder }}</option>
        {% endif %}
        {% for option in field.options %}
        <option value="{{ option.value }}">{{ option.text }}</option>
        {% endfor %}
      </select>
      {% else %}
      <input
        type="{{ field.type | default('text') }}"
        id="field-{{ field.name }}"
        name="{{ field.name }}"
        {% if field.placeholder %}placeholder="{{ field.placeholder }}"{% endif %}
        {% if field.required %}required{% endif %}
        style="margin-top: 0.25rem; width: 100%; border-radius: 0.5rem; border: 1px solid var(--color-border, #d1d5db); padding: 0.5rem 0.75rem; outline: none;"
      >
      {% endif %}
    </div>
    {% endfor %}

    {# Standalone select fields (for backward compatibility / simpler config) #}
    {% for sel in block.select_fields %}
    <div>
      <label
        for="select-{{ sel.name }}"
        style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--color-text); margin-bottom: 0.25rem;"
      >
        {{ sel.label }}{% if sel.required %} <span style="color: var(--color-danger, #ef4444);" aria-hidden="true">*</span>{% endif %}
      </label>

      <select
        id="select-{{ sel.name }}"
        name="{{ sel.name }}"
        {% if sel.required %}required{% endif %}
        style="margin-top: 0.25rem; width: 100%; border-radius: 0.5rem; border: 1px solid var(--color-border, #d1d5db); padding: 0.5rem 0.75rem; outline: none; background: white;"
      >
        <option value="">Select {{ sel.label | lower }}</option>
        {% for option in sel.options %}
        <option value="{{ option.value }}">{{ option.text }}</option>
        {% endfor %}
      </select>
    </div>
    {% endfor %}

    <button type="submit" class="btn-primary" style="width: 100%; padding: 0.75rem 3rem; font-size: 0.875rem; font-weight: 500; border-radius: 0.5rem;">
      {{ block.cta_text | default('Send Message') }}
    </button>
  </form>
</section>
