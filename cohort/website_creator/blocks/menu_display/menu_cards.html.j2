{# Menu: Card-per-item layout with optional photo, 2-column grid.
   Tags: modern, dense
   Variables: block.section_headline,
              block.categories [{name, items: [{name, description, price, dietary_tags, image}]}]
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {% if block.section_headline %}
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold" style="font-family: var(--font-heading);">{{ block.section_headline }}</h2>
    </div>
    {% endif %}

    {% for category in block.categories %}
    <div class="{% if not loop.first %}mt-12{% endif %}">
      <h3 class="text-xl font-semibold text-primary mb-6" style="font-family: var(--font-heading);">{{ category.name }}</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {% for item in category["items"] %}
        <article class="bg-white border border-theme rounded-theme overflow-hidden flex {% if item.image %}flex-col sm:flex-row{% else %}flex-row{% endif %}">
          {% if item.image %}
          <div class="sm:w-36 sm:flex-shrink-0">
            <img src="{{ item.image }}" alt="{{ item.name }}" class="w-full h-36 sm:h-full object-cover" loading="lazy">
          </div>
          {% endif %}
          <div class="p-4 flex flex-col justify-between flex-1 min-w-0">
            <div>
              <div class="flex justify-between items-baseline gap-3">
                <h4 class="text-base font-semibold truncate" style="font-family: var(--font-heading);">{{ item.name }}</h4>
                <span class="text-base font-semibold text-primary flex-shrink-0">{{ item.price }}</span>
              </div>
              {% if item.description %}
              <p class="mt-1 text-sm text-muted leading-relaxed">{{ item.description }}</p>
              {% endif %}
            </div>
            {% if item.dietary_tags %}
            <div class="flex gap-1 mt-2">
              {% for tag in item.dietary_tags %}
              <span class="inline-block text-xs font-medium text-primary border border-theme rounded-theme px-1.5 py-0.5">{{ tag }}</span>
              {% endfor %}
            </div>
            {% endif %}
          </div>
        </article>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
</section>
