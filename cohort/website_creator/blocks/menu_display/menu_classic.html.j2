{# Menu: Classic restaurant menu with category headers, items with name/description/price.
   Tags: formal, warm
   Variables: block.section_headline,
              block.categories [{name, items: [{name, description, price, dietary_tags}]}]
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    {% if block.section_headline %}
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold" style="font-family: var(--font-heading);">{{ block.section_headline }}</h2>
    </div>
    {% endif %}

    <div class="space-y-12">
      {% for category in block.categories %}
      <div>
        <h3 class="text-2xl font-semibold text-primary mb-6 text-center" style="font-family: var(--font-heading);">{{ category.name }}</h3>
        <div class="space-y-0">
          {% for item in category["items"] %}
          <div class="py-5 {% if not loop.last %}border-b border-theme{% endif %}">
            <div class="flex justify-between items-baseline gap-4">
              <div class="flex items-baseline gap-2 min-w-0">
                <h4 class="text-lg font-semibold whitespace-nowrap" style="font-family: var(--font-heading);">{{ item.name }}</h4>
                {% if item.dietary_tags %}
                <div class="flex gap-1 flex-shrink-0">
                  {% for tag in item.dietary_tags %}
                  <span class="inline-block text-xs font-medium text-primary border border-theme rounded-theme px-1.5 py-0.5">{{ tag }}</span>
                  {% endfor %}
                </div>
                {% endif %}
              </div>
              <span class="text-lg font-semibold text-primary flex-shrink-0">{{ item.price }}</span>
            </div>
            {% if item.description %}
            <p class="mt-1 text-muted leading-relaxed">{{ item.description }}</p>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
