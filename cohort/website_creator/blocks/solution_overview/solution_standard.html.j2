{# Solution Overview: Feature cards showing how the product addresses problems.
   Tags: conventional, formal
   Variables: block.headline, block.subheadline,
              block.features [{title, description, image}]
#}
<section class="section-alt py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Section header #}
    {% if block.headline %}
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="font-family: var(--font-heading);">{{ block.headline }}</h2>
      {% if block.subheadline %}
      <p class="text-lg text-muted leading-relaxed">{{ block.subheadline }}</p>
      {% endif %}
    </div>
    {% endif %}

    {# Feature cards #}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for feature in block.features %}
      <div class="bg-white border border-theme rounded-theme overflow-hidden">
        {# Feature image #}
        {% if feature.image %}
        <div class="aspect-video overflow-hidden">
          <img
            src="{{ feature.image }}"
            alt="{{ feature.title }}"
            loading="lazy"
            class="w-full h-full object-cover"
          >
        </div>
        {% endif %}

        {# Content #}
        <div class="p-6 sm:p-8">
          <h3 class="text-lg font-semibold mb-2" style="font-family: var(--font-heading);">{{ feature.title }}</h3>
          <p class="text-muted leading-relaxed">{{ feature.description }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
