{# Logo Cloud: Grayscale row -- partner/certification logos in a row. Adapted from HyperUI (MIT).
   Tags: trust, social-proof, minimal
   Variables: block.heading, block.logos [{name, image, url}]
#}
<section style="padding: 3rem 0;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    {% if block.heading %}
    <p style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text); opacity: 0.5;">{{ block.heading }}</p>
    {% endif %}
    <div style="margin-top: 1.5rem; display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap;">
      {% for logo in block.logos %}
      {% if logo.url %}
      <a href="{{ logo.url }}" target="_blank" rel="noopener" style="opacity: 0.5; transition: opacity 0.2s; filter: grayscale(100%);" onmouseover="this.style.opacity='1';this.style.filter='none'" onmouseout="this.style.opacity='0.5';this.style.filter='grayscale(100%)'">
        {% if logo.image %}
        <img src="{{ logo.image }}" alt="{{ logo.name }}" style="height: 2.5rem; max-width: 8rem; object-fit: contain;">
        {% else %}
        <span style="font-weight: 700; font-size: 1.1rem; color: var(--color-text);">{{ logo.name }}</span>
        {% endif %}
      </a>
      {% else %}
      <div style="opacity: 0.5;">
        {% if logo.image %}
        <img src="{{ logo.image }}" alt="{{ logo.name }}" style="height: 2.5rem; max-width: 8rem; object-fit: contain; filter: grayscale(100%);">
        {% else %}
        <span style="font-weight: 700; font-size: 1.1rem; color: var(--color-text);">{{ logo.name }}</span>
        {% endif %}
      </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
