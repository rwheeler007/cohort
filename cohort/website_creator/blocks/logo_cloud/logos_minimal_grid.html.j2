{# Logo Cloud: No heading -- clean borderless grid of logos on tinted cells.
   Adapted from HyperUI logo-clouds/4 (MIT).
   Tags: trust, social-proof, minimal, no-heading
   Variables: block.logos [{name, image, url}]
#}
<section class="section-spacing">
  <div style="max-width: 72rem; margin: 0 auto; padding: 0 1rem;">
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; overflow: hidden; border-radius: var(--radius);">
      {% for logo in block.logos %}
      <div style="display: grid; place-content: center; aspect-ratio: 16/9; padding: 1.5rem; background: var(--color-accent); filter: grayscale(100%); transition: filter 0.3s;" onmouseover="this.style.filter='none'" onmouseout="this.style.filter='grayscale(100%)'">
        {% if logo.url %}
        <a href="{{ logo.url }}" target="_blank" rel="noopener">
        {% endif %}
          {% if logo.image %}
          <img src="{{ logo.image }}" alt="{{ logo.name }}" style="height: 2rem; max-width: 10rem; object-fit: contain;">
          {% else %}
          <span style="font-weight: 700; font-size: 1.1rem; color: var(--color-text);">{{ logo.name }}</span>
          {% endif %}
        {% if logo.url %}
        </a>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>
<style>
@media (min-width: 768px) {
  .section-spacing > div > div:first-child { grid-template-columns: repeat(4, 1fr); }
}
</style>
