{# Testimonials: 2-3 column grid of quote cards with name, title, company.
   Tags: conventional, formal
   Variables: block.testimonials [{quote, name, title, company}]
#}
<section class="bg-white py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for t in block.testimonials %}
      <figure class="bg-white border border-theme rounded-theme p-6 sm:p-8">
        <svg class="w-8 h-8 text-primary/30 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
        </svg>
        <blockquote>
          <p class="text-gray-700 leading-relaxed">{{ t.quote }}</p>
        </blockquote>
        <figcaption class="mt-6 flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-alt flex items-center justify-center flex-shrink-0">
            <span class="text-sm font-semibold text-primary">{{ t.name[0] | upper }}</span>
          </div>
          <div>
            <div class="font-semibold text-sm">{{ t.name }}</div>
            {% if t.title or t.company %}
            <div class="text-muted text-xs">{{ t.title }}{% if t.title and t.company %}, {% endif %}{{ t.company }}</div>
            {% endif %}
          </div>
        </figcaption>
      </figure>
      {% endfor %}
    </div>
  </div>
</section>
