{# Testimonials: Single spotlight -- one large featured quote. Good for hero-adjacent placement.
   Tags: bold, focused, high-impact
   Variables: block.testimonials [{quote, name, title, company, photo}]
#}
<section class="section-spacing" style="background: var(--color-accent);">
  <div style="max-width: 48rem; margin: 0 auto; padding: 0 1rem; text-align: center;">
    {% set t = block.testimonials[0] if block.testimonials else {} %}
    <div style="color: var(--color-primary); font-size: 3rem; line-height: 1; margin-bottom: 1.5rem; opacity: 0.3;">"</div>
    <blockquote style="font-size: 1.35rem; line-height: 1.8; font-style: italic; color: var(--color-text);">
      {{ t.quote | default('') }}
    </blockquote>
    <div style="margin-top: 2rem; display: flex; align-items: center; justify-content: center; gap: 1rem;">
      {% if t.photo %}
      <img src="{{ t.photo }}" alt="{{ t.name }}" style="width: 48px; height: 48px; border-radius: 50%; object-fit: cover;">
      {% endif %}
      <div>
        <div style="font-weight: 700; color: var(--color-text);">{{ t.name | default('') }}</div>
        {% if t.title %}
        <div style="font-size: 0.85rem; color: var(--color-text); opacity: 0.6;">{{ t.title }}{% if t.company %} -- {{ t.company }}{% endif %}</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
