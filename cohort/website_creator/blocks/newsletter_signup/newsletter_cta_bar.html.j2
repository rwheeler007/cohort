{# Newsletter: CTA bar -- centered heading with inline email + submit. Adapted from HyperUI (MIT).
   Tags: conversion, lead-gen, minimal
   Variables: block.heading, block.subheading, block.button_text, block.form_action
#}
<section class="section-spacing" style="background: var(--color-accent);">
  <div style="max-width: 36rem; margin: 0 auto; text-align: center; padding: 0 1rem;">
    <h2 style="font-size: 1.5rem; font-weight: 700; font-family: var(--font-heading); color: var(--color-text);">
      {{ block.heading | default('Stay in the loop') }}
    </h2>

    {% if block.subheading %}
    <p style="margin-top: 0.75rem; color: var(--color-text); opacity: 0.7;">{{ block.subheading }}</p>
    {% endif %}

    <form action="{{ block.form_action | default('#') }}" method="POST" style="margin-top: 1.5rem; display: flex; gap: 0.5rem; max-width: 28rem; margin-left: auto; margin-right: auto;">
      <label for="nl-email" class="sr-only">Email</label>
      <input type="email" id="nl-email" name="email" placeholder="you@example.com" required style="flex: 1; padding: 0.75rem 1rem; border: 1px solid #d1d5db; border-radius: var(--radius); font-size: 0.9rem;">
      <button type="submit" class="btn-primary" style="padding: 0.75rem 1.5rem; white-space: nowrap;">
        {{ block.button_text | default('Subscribe') }}
      </button>
    </form>
  </div>
</section>
