{# Newsletter: Inline email input with heading and submit button.
   Tags: minimal, modern
   Variables: block.heading, block.description, block.button_text
#}
<section class="bg-white py-16 sm:py-20">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    {% if block.heading %}
    <h2 class="text-2xl sm:text-3xl font-bold" style="font-family: var(--font-heading);">{{ block.heading }}</h2>
    {% endif %}
    {% if block.description %}
    <p class="mt-3 text-muted leading-relaxed">{{ block.description }}</p>
    {% endif %}
    <form action="{{ block.form_action | default('#') }}" method="POST" class="mt-8 flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input type="email" id="newsletter-email" name="email" required placeholder="Enter your email" class="flex-1 px-4 py-3 border border-theme rounded-theme focus:outline-none focus:ring-2 focus:ring-offset-0 text-sm" style="--tw-ring-color: var(--color-primary);">
      <button type="submit" class="btn-primary px-6 py-3 text-sm font-semibold whitespace-nowrap">
        {{ block.button_text | default('Subscribe') }}
      </button>
    </form>
  </div>
</section>
