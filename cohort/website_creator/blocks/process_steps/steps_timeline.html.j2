{# Process Steps: Vertical timeline with connecting line, numbered dots left, content right.
   Tags: modern, creative
   Variables: block.heading, block.steps [{number, title, description}]
#}
<section class="py-16 sm:py-20 lg:py-24">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    {% if block.heading %}
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold" style="font-family: var(--font-heading);">{{ block.heading }}</h2>
    </div>
    {% endif %}

    <ol class="relative list-none p-0 m-0">
      {# Vertical connecting line #}
      <div class="absolute left-5 sm:left-6 top-0 bottom-0 w-0.5 bg-alt" aria-hidden="true" style="background-color: var(--color-border);"></div>

      {% for step in block.steps %}
      <li class="relative pl-16 sm:pl-20 pb-12 {{ 'pb-0' if loop.last else '' }}">
        {# Numbered dot #}
        <div class="absolute left-0 w-10 h-10 sm:w-12 sm:h-12 flex items-center justify-center rounded-full bg-primary text-white text-sm sm:text-base font-bold shrink-0 z-10" aria-hidden="true">
          {{ step.number | default(loop.index) }}
        </div>

        {# Content #}
        <div class="pt-1 sm:pt-2">
          <h3 class="text-lg font-semibold mb-2" style="font-family: var(--font-heading);">
            <span class="sr-only">Step {{ step.number | default(loop.index) }}: </span>{{ step.title }}
          </h3>
          <p class="text-muted leading-relaxed">{{ step.description }}</p>
        </div>
      </li>
      {% endfor %}
    </ol>
  </div>
</section>
