{# Team Section: Compact avatar grid -- circular photos in a 6-column grid with name and role.
   Adapted from HyperUI team-sections/3 (MIT).
   Tags: compact, minimal, avatar-focused
   Variables: block.section_headline, block.section_description,
              block.members [{name, role, photo, bio}]
#}
<section class="section-spacing">
  <div style="max-width: 72rem; margin: 0 auto; padding: 0 1rem;">
    {% if block.section_headline %}
    <div style="text-align: center; max-width: 48rem; margin: 0 auto 3rem;">
      <h2 style="font-family: var(--font-heading); font-size: 1.875rem; font-weight: 700;">{{ block.section_headline }}</h2>
      {% if block.section_description %}
      <p style="margin-top: 1rem; color: var(--color-text); opacity: 0.7; line-height: 1.7;">{{ block.section_description }}</p>
      {% endif %}
    </div>
    {% endif %}

    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem;">
      {% for member in block.members %}
      <div style="text-align: center;">
        {% if member.photo %}
        <img src="{{ member.photo }}" alt="{{ member.name }}" style="width: 100%; aspect-ratio: 1/1; border-radius: 9999px; object-fit: cover;">
        {% else %}
        <div style="width: 100%; aspect-ratio: 1/1; border-radius: 9999px; background: var(--color-accent); display: flex; align-items: center; justify-content: center;">
          <svg style="width: 3rem; height: 3rem; color: var(--color-text); opacity: 0.3;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/>
          </svg>
        </div>
        {% endif %}

        <div style="margin-top: 1rem;">
          <h3 style="font-family: var(--font-heading); font-size: 1.1rem; font-weight: 600; color: var(--color-text); line-height: 1.2;">{{ member.name }}</h3>
          {% if member.role %}
          <p style="margin-top: 0.25rem; font-size: 0.875rem; color: var(--color-text); opacity: 0.6;">{{ member.role }}</p>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
<style>
@media (min-width: 640px) {
  .section-spacing > div > div:last-child { grid-template-columns: repeat(3, 1fr); }
}
@media (min-width: 1024px) {
  .section-spacing > div > div:last-child { grid-template-columns: repeat(6, 1fr); }
}
</style>
