{# Team / About Page -- company story + team member cards #}
{% extends "base.html.j2" %}

{% block content %}
<!-- Team Hero -->
<section class="section-spacing" style="background: {{ brand.accent_color }};">
    <div class="container text-center">
        <h1 class="responsive-h1">{% if page.content.headline %}{{ page.content.headline }}{% else %}Meet the Team{% endif %}</h1>
        <p class="responsive-p-large">{% if page.content.subheadline %}{{ page.content.subheadline }}{% else %}The people behind {{ product_name }}.{% endif %}</p>
    </div>
</section>

{% if page.content.story %}
<!-- Our Story -->
<section class="section-spacing">
    <div class="container" style="max-width: 800px;">
        {% if page.content.story_heading %}
        <h2 class="responsive-h2 text-center" style="margin-bottom: 2rem;">{{ page.content.story_heading }}</h2>
        {% endif %}
        <div class="responsive-p-body" style="max-width: none; line-height: 1.8;">{{ page.content.story }}</div>
    </div>
</section>
{% endif %}

{% if page.content.core_values %}
<!-- Values -->
<section class="section-spacing" style="background: #f9fafb;">
    <div class="container text-center">
        <h2 class="responsive-h2">{% if page.content.core_values_heading %}{{ page.content.core_values_heading }}{% else %}What We Stand For{% endif %}</h2>
        <div class="grid-3" style="margin-top: 2rem;">
            {% for value in page.content.core_values %}
            <div class="card text-center">
                {% if value.icon %}
                <div style="font-size: 2rem; margin-bottom: 1rem;">{{ value.icon }}</div>
                {% endif %}
                <h3 class="responsive-h3">{{ value.title }}</h3>
                <p class="responsive-p-body">{{ value.description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if page.content.team_members %}
<!-- Team Members -->
<section class="section-spacing">
    <div class="container text-center">
        <h2 class="responsive-h2">{% if page.content.team_heading %}{{ page.content.team_heading }}{% else %}Our Team{% endif %}</h2>
        <div class="grid-{{ [page.content.team_members|length, 4] | min }}" style="margin-top: 2rem;">
            {% for member in page.content.team_members %}
            <div class="card text-center" style="padding: 2rem 1.5rem;">
                {% if member.photo %}
                <img src="{{ member.photo }}" alt="{{ member.name }}" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; margin: 0 auto 1rem;">
                {% else %}
                <div style="width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, {{ brand.primary_color }}, {{ brand.secondary_color }}); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: #fff; font-weight: 700; font-size: 1.5rem;">{{ member.name[:1] }}</div>
                {% endif %}
                <h3 class="responsive-h3" style="margin-bottom: 0.25rem;">{{ member.name }}</h3>
                {% if member.role %}
                <div style="color: {{ brand.primary_color }}; font-weight: 500; font-size: 0.9rem; margin-bottom: 0.75rem;">{{ member.role }}</div>
                {% endif %}
                {% if member.bio %}
                <p class="responsive-p-body" style="font-size: 0.9rem; opacity: 0.8;">{{ member.bio }}</p>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if page.content.stats %}
<!-- Stats Banner -->
<section class="section-spacing" style="background: {{ brand.secondary_color }}; color: #fff;">
    <div class="container">
        <div class="grid-{{ [page.content.stats|length, 4] | min }}" style="text-align: center;">
            {% for stat in page.content.stats %}
            <div>
                <div style="font-size: 2.5rem; font-weight: 700;">{{ stat.value }}</div>
                <div style="opacity: 0.8; margin-top: 0.25rem;">{{ stat.label }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if page.content.certifications %}
<!-- Certifications / Trust -->
<section class="section-spacing">
    <div class="container text-center">
        <h2 class="responsive-h2">{% if page.content.cert_heading %}{{ page.content.cert_heading }}{% else %}Certifications & Awards{% endif %}</h2>
        <div style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem; align-items: center;">
            {% for cert in page.content.certifications %}
            <div class="card" style="min-width: 160px; text-align: center;">
                {% if cert.image %}
                <img src="{{ cert.image }}" alt="{{ cert.name }}" style="max-height: 60px; margin-bottom: 0.75rem;">
                {% endif %}
                <div style="font-weight: 600; font-size: 0.9rem;">{{ cert.name }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<!-- CTA -->
<section class="section-spacing" style="background: {{ brand.accent_color }};">
    <div class="container text-center">
        <h2 class="responsive-h2">{% if page.content.cta_heading %}{{ page.content.cta_heading }}{% else %}Work With Us{% endif %}</h2>
        <div class="button-group">
            <a href="{{ page.content.cta_href | default('contact.html') }}" class="btn-primary">{{ page.content.cta_text | default('Get in Touch') }}</a>
        </div>
    </div>
</section>
{% endblock %}
