{# FAQ Page -- accordion-style questions and answers #}
{% extends "base.html.j2" %}

{% block content %}
<!-- FAQ Hero -->
<section class="section-spacing" style="background: {{ brand.accent_color }};">
    <div class="container text-center">
        <h1 class="responsive-h1">{% if page.content.headline %}{{ page.content.headline }}{% else %}Frequently Asked Questions{% endif %}</h1>
        <p class="responsive-p-large">{% if page.content.subheadline %}{{ page.content.subheadline }}{% else %}Find answers to common questions.{% endif %}</p>
    </div>
</section>

{% if page.content.faqs %}
<!-- FAQ Accordion -->
<section class="section-spacing">
    <div class="container" style="max-width: 800px;">
        {% if page.content.sections %}
            {% for section in page.content.sections %}
            <h2 class="responsive-h2" style="margin-bottom: 1.5rem;{% if not loop.first %} margin-top: 3rem;{% endif %}">{{ section.heading }}</h2>
            {% for faq in section.items %}
            <details class="faq-item" style="border-bottom: 1px solid #e5e7eb; padding: 1.25rem 0;">
                <summary style="cursor: pointer; font-weight: 600; font-size: 1.05rem; list-style: none; display: flex; justify-content: space-between; align-items: center;">
                    {{ faq.question }}
                    <span class="faq-chevron" style="transition: transform 0.2s; font-size: 0.8rem; opacity: 0.4;">&#9660;</span>
                </summary>
                <div style="padding-top: 1rem; line-height: 1.7; opacity: 0.85;">{{ faq.answer }}</div>
            </details>
            {% endfor %}
            {% endfor %}
        {% else %}
            {% for faq in page.content.faqs %}
            <details class="faq-item" style="border-bottom: 1px solid #e5e7eb; padding: 1.25rem 0;">
                <summary style="cursor: pointer; font-weight: 600; font-size: 1.05rem; list-style: none; display: flex; justify-content: space-between; align-items: center;">
                    {{ faq.question }}
                    <span class="faq-chevron" style="transition: transform 0.2s; font-size: 0.8rem; opacity: 0.4;">&#9660;</span>
                </summary>
                <div style="padding-top: 1rem; line-height: 1.7; opacity: 0.85;">{{ faq.answer }}</div>
            </details>
            {% endfor %}
        {% endif %}
    </div>
</section>
{% endif %}

<!-- Still Have Questions -->
<section class="section-spacing" style="background: {{ brand.accent_color }};">
    <div class="container text-center">
        <h2 class="responsive-h2">{% if page.content.cta_heading %}{{ page.content.cta_heading }}{% else %}Still Have Questions?{% endif %}</h2>
        <p class="responsive-p-large">{% if page.content.cta_subheading %}{{ page.content.cta_subheading }}{% else %}We're here to help. Reach out anytime.{% endif %}</p>
        <div class="button-group">
            <a href="{{ page.content.cta_href | default('contact.html') }}" class="btn-primary">{{ page.content.cta_text | default('Contact Us') }}</a>
            {% if contact.phone %}
            <a href="tel:{{ contact.phone | replace(' ', '') | replace('(', '') | replace(')', '') | replace('-', '') }}" class="btn-secondary">{{ contact.phone }}</a>
            {% endif %}
        </div>
    </div>
</section>

<style>
details[open] .faq-chevron { transform: rotate(180deg); }
details summary::-webkit-details-marker { display: none; }
</style>
{% endblock %}
