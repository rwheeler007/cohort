{# Marketing Pipeline Page -- bespoke layout for content marketing showcase #}
{% extends "base.html.j2" %}

{% block head_extra %}
<style>
.desktop-break { display: none; }
@media (min-width: 640px) { .desktop-break { display: inline; } }
</style>
{% endblock %}

{% block content %}
{# --- Aliases for brevity --- #}
{% set c = page.content %}
{% set hero_cfg = c.hero | default({}) %}
{% set before_after = c.before_after | default({}) %}
{% set pipeline = c.pipeline | default({}) %}
{% set differentiators = c.differentiators | default([]) %}
{% set showcase = c.showcase | default({}) %}
{% set stats = c.stats | default([]) %}
{% set workflow_steps = c.workflow_steps | default([]) %}
{% set real_run = c.real_run | default({}) %}
{% set cta = c.cta | default({}) %}

{# ============================================================
   Hero
   ============================================================ #}
<section class="section-spacing-hero" style="background: {{ brand.secondary_color }}; color: #fff; padding: 4rem 0;">
    <div class="container text-center">
        <h1 class="responsive-h1" style="color: #fff;">{{ hero_cfg.headline | default('Your AI Marketing Team.') }}<br class="desktop-break"> {{ hero_cfg.headline_line2 | default('Works While You Sleep.') }}</h1>
        <p class="responsive-p-large" style="color: rgba(255,255,255,0.9);">{{ hero_cfg.subheadline | default('') }}</p>
        <div class="button-group">
            {% if hero_cfg.cta_primary_text %}
            <a href="{{ hero_cfg.cta_primary_href | default('#') }}" class="btn-primary" style="background: {{ brand.primary_color }}; color: #fff;">{{ hero_cfg.cta_primary_text }}</a>
            {% endif %}
            {% if hero_cfg.cta_secondary_text %}
            <a href="{{ hero_cfg.cta_secondary_href | default('#pipeline') }}" class="btn-secondary" style="border-color: #fff; color: #fff; background: rgba(255,255,255,0.1);">{{ hero_cfg.cta_secondary_text }}</a>
            {% endif %}
        </div>
    </div>
</section>

{# ============================================================
   Before / After
   ============================================================ #}
{% if before_after %}
<section class="section-spacing" style="background: {{ brand.accent_color }};">
    <div class="container">
        <h2 class="responsive-h2 text-center">{{ before_after.heading | default('Monday Morning: Before vs. After') }}</h2>
        <div class="grid-2" style="margin-top: 2rem; max-width: 960px; margin-left: auto; margin-right: auto;">
            {# Before #}
            <div class="card" style="border-top: 4px solid #888;">
                <h3 style="font-family: var(--font-heading); font-size: 1rem; margin-bottom: 1.25rem; color: #888;">{{ before_after.before_label | default('Without Cohort') }}</h3>
                <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem; line-height: 1.8;">
                    {% for item in before_after.before_items | default([]) %}
                    <li style="padding: 0.3rem 0;">{{ item }}</li>
                    {% endfor %}
                </ul>
                <div style="margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
                    <span style="font-size: 2rem; font-weight: 700; color: #888;">{{ before_after.before_time | default('~6 hours') }}</span>
                    <span style="font-size: 0.85rem; color: #888; display: block;">{{ before_after.before_time_label | default('per content cycle') }}</span>
                </div>
            </div>
            {# After #}
            <div class="card" style="border-top: 4px solid var(--color-primary);">
                <h3 style="font-family: var(--font-heading); font-size: 1rem; margin-bottom: 1.25rem; color: var(--color-primary);">{{ before_after.after_label | default('With Cohort') }}</h3>
                <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.9rem; line-height: 1.8;">
                    {% for item in before_after.after_items | default([]) %}
                    <li style="padding: 0.3rem 0;">{{ item }}</li>
                    {% endfor %}
                    {# Spacer to match height if fewer items #}
                    {% for _ in range(before_after.before_items | default([]) | length - before_after.after_items | default([]) | length) %}
                    <li style="padding: 0.3rem 0; color: transparent; user-select: none;">.</li>
                    {% endfor %}
                </ul>
                <div style="margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid #e5e7eb;">
                    <span style="font-size: 2rem; font-weight: 700; color: var(--color-primary);">{{ before_after.after_time | default('~30 min') }}</span>
                    <span style="font-size: 0.85rem; color: var(--color-text); display: block;">{{ before_after.after_time_label | default('review and publish') }}</span>
                </div>
            </div>
        </div>
    </div>
</section>
{% endif %}

{# ============================================================
   The Pipeline
   ============================================================ #}
{% if pipeline.agents is defined %}
<section id="pipeline" class="section-spacing">
    <div class="container" style="max-width: 900px;">
        <h2 class="responsive-h2 text-center">{{ pipeline.heading | default('The Pipeline') }}</h2>
        <p class="responsive-p-large text-center">{{ pipeline.subheadline | default('') }}</p>

        {# Pipeline visual - vertical timeline #}
        <div style="margin-top: 2rem; display: flex; flex-direction: column; gap: 0;">
            {% for agent in pipeline.agents %}
            <div style="display: flex; align-items: stretch; gap: 0;">
                <div style="width: 4rem; flex-shrink: 0; display: flex; flex-direction: column; align-items: center;">
                    <div style="width: 3rem; height: 3rem; border-radius: 50%; background: {{ agent.color }}; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.8rem; flex-shrink: 0;">{{ agent.abbrev }}</div>
                    {% if not loop.last %}
                    <div style="width: 2px; flex: 1; background: #d1d5db;"></div>
                    {% else %}
                    <div style="width: 2px; flex: 0; background: transparent;"></div>
                    {% endif %}
                </div>
                <div style="padding: 0.25rem 0 {% if not loop.last %}2rem{% else %}0{% endif %} 0.75rem;">
                    <h3 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.25rem;">{{ agent.name }}</h3>
                    <p style="font-size: 0.85rem; color: #555; margin: 0; line-height: 1.5;">{{ agent.description }}</p>
                    {% if agent.log_line %}
                    <div style="margin-top: 0.5rem; font-family: monospace; font-size: 0.75rem; color: #888;">{{ agent.log_line }}</div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>

        {# Terminal log #}
        {% if pipeline.terminal_log %}
        <div style="margin-top: 2.5rem; background: #2D2D2D; border-radius: 8px; padding: 1.5rem; font-family: monospace; font-size: 0.8rem; line-height: 1.7; color: #C8C8C8; overflow-x: auto;">
            <div style="color: #888; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; font-family: -apple-system, sans-serif;">{{ pipeline.terminal_log.label | default('Real pipeline log -- nightly schedule') }}</div>
<pre style="margin: 0; white-space: pre-wrap;">{% for entry in pipeline.terminal_log.entries %}<span style="color: #888;">{{ entry.time }}</span>  <span style="color: {{ entry.color }};">{{ entry.agent }}</span>   {{ entry.action }}
{% endfor %}</pre>
        </div>
        {% endif %}
    </div>
</section>
{% endif %}

{# ============================================================
   What Makes This Different -- differentiator cards
   ============================================================ #}
{% if differentiators %}
<section class="section-spacing" style="background: #f9fafb;">
    <div class="container">
        <h2 class="responsive-h2 text-center">{{ c.differentiators_heading | default('Not Another AI Writing Tool') }}</h2>
        <p class="responsive-p-large text-center">{{ c.differentiators_subheadline | default('') }}</p>

        <div class="grid-3" style="margin-top: 2rem;">
            {% for diff in differentiators %}
            <div class="card text-center">
                {% if diff.icon %}
                <div style="font-size: 2rem; margin-bottom: 1rem;" role="img" aria-label="{{ diff.title }}">{{ diff.icon }}</div>
                {% endif %}
                <h3 class="responsive-h3">{{ diff.title }}</h3>
                <p class="responsive-p-body">{{ diff.description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ============================================================
   Output Showcase -- tabbed: Blog / Social / Briefing
   ============================================================ #}
{% if showcase.tabs is defined %}
<section class="section-spacing">
    <div class="container" style="max-width: 900px;">
        <h2 class="responsive-h2 text-center">{{ showcase.heading | default('What You Wake Up To') }}</h2>
        <p class="responsive-p-large text-center">{{ showcase.subheadline | default('') }}</p>

        {# Tab buttons #}
        <div style="display: flex; gap: 0; margin-top: 2rem; border-bottom: 2px solid #e5e7eb;" role="tablist">
            {% for tab in showcase.tabs %}
            <button role="tab" aria-selected="{{ 'true' if loop.first else 'false' }}" id="tab-{{ tab.id }}" onclick="showTab('{{ tab.id }}')" style="flex: 1; padding: 0.75rem 1rem; border: none; background: {% if loop.first %}var(--color-primary){% else %}#e5e7eb{% endif %}; color: {% if loop.first %}#fff{% else %}var(--color-text){% endif %}; font-weight: 600; font-size: 0.85rem; cursor: pointer; border-radius: 4px 4px 0 0; font-family: var(--font-body);">{{ tab.label }}</button>
            {% endfor %}
        </div>

        {# Tab panels #}
        {% for tab in showcase.tabs %}
        <div id="panel-{{ tab.id }}" role="tabpanel" style="{% if not loop.first %}display: none; {% endif %}{% if tab.dark %}background: #0d1117; border: 1px solid #30363d; color: #e6edf3;{% else %}background: #fff; border: 1px solid #e5e7eb;{% endif %} border-top: none; border-radius: 0 0 8px 8px; padding: 2rem;">
            {{ tab.html_content }}
        </div>
        {% endfor %}
    </div>
</section>
{% endif %}

{# ============================================================
   Stats Banner
   ============================================================ #}
{% if stats %}
<section class="section-spacing" style="background: {{ brand.secondary_color }}; color: #fff;">
    <div class="container">
        <div style="display: grid; grid-template-columns: repeat({{ [stats | length, 4] | min }}, 1fr); gap: 1.5rem; max-width: 800px; margin: 0 auto;">
            {% for stat in stats %}
            <div style="text-align: center; padding: 1.5rem;">
                <div style="font-size: 3rem; font-weight: 700; color: {{ stat.color | default(brand.primary_color) }};">{{ stat.value }}</div>
                <div style="font-size: 0.9rem; color: rgba(255,255,255,0.8);">{{ stat.label }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ============================================================
   How It Fits Your Workflow
   ============================================================ #}
{% if workflow_steps %}
<section class="section-spacing">
    <div class="container" style="max-width: 860px;">
        <h2 class="responsive-h2 text-center">{{ c.workflow_heading | default('How It Fits Your Workflow') }}</h2>
        <div style="margin-top: 2rem;">
            {% for step in workflow_steps %}
            <div style="display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 2rem;">
                <div style="flex-shrink: 0; width: 3rem; height: 3rem; border-radius: 50%; background: var(--color-primary); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.25rem;">{{ loop.index }}</div>
                <div>
                    <h3 class="responsive-h3 mb-0">{{ step.title }}</h3>
                    <p class="responsive-p-body" style="max-width: none;">{{ step.description }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ============================================================
   Real Run Case Study
   ============================================================ #}
{% if real_run.steps is defined %}
<section class="section-spacing" style="background: #f9fafb;">
    <div class="container" style="max-width: 960px;">
        <h2 class="responsive-h2 text-center">{{ real_run.heading | default('See It In Action: A Real Run') }}</h2>
        <p class="responsive-p-large text-center">{{ real_run.subheadline | default('') }}</p>

        {% for step in real_run.steps %}
        <div style="margin-top: {% if loop.first %}2.5rem{% else %}0{% endif %}; border-left: 3px solid {{ step.color }}; padding-left: 1.5rem; margin-bottom: 2.5rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                <div style="width: 2.5rem; height: 2.5rem; border-radius: 50%; background: {{ step.color }}; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.75rem; flex-shrink: 0;">{{ step.abbrev }}</div>
                <div>
                    <h3 style="font-size: 1.1rem; font-weight: 700; margin: 0;">{{ step.title }}</h3>
                    <div style="font-size: 0.8rem; color: #888;">{{ step.date_label }}</div>
                </div>
            </div>
            {% if step.intro %}
            <p style="font-size: 0.9rem; color: #555; margin-bottom: 1rem;">{{ step.intro }}</p>
            {% endif %}
            {# Freeform HTML block for rich content (terminal logs, cards, etc.) #}
            {{ step.html_content | default('') }}
            {% if step.footnote %}
            <p style="font-size: 0.8rem; color: #888; margin-top: 0.5rem; font-style: italic;">{{ step.footnote }}</p>
            {% endif %}
        </div>
        {% endfor %}

        {# Result summary #}
        {% if real_run.result %}
        <div style="background: #fff; border: 2px solid var(--color-primary); border-radius: 8px; padding: 1.5rem; text-align: center;">
            <h3 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 0.75rem;">{{ real_run.result.heading | default('End Result') }}</h3>
            {% if real_run.result.stats %}
            <div style="display: grid; grid-template-columns: repeat({{ [real_run.result.stats | length, 4] | min }}, 1fr); gap: 1rem; margin-bottom: 1rem;">
                {% for stat in real_run.result.stats %}
                <div>
                    <div style="font-size: 1.5rem; font-weight: 700; color: {{ stat.color | default('var(--color-primary)') }};">{{ stat.value }}</div>
                    <div style="font-size: 0.75rem; color: #888;">{{ stat.label }}</div>
                </div>
                {% endfor %}
            </div>
            {% endif %}
            {% if real_run.result.summary %}
            <p style="font-size: 0.85rem; color: #555; margin: 0;">{{ real_run.result.summary }}</p>
            {% endif %}
        </div>
        {% endif %}
    </div>
</section>
{% endif %}

{# ============================================================
   Final CTA
   ============================================================ #}
<section class="section-spacing" style="background: {{ brand.accent_color }};">
    <div class="container text-center">
        <h2 class="responsive-h2">{{ cta.heading | default('Ready to Get Started?') }}</h2>
        <p class="responsive-p-large">{{ cta.subheadline | default('') }}</p>
        <div class="button-group">
            {% if cta.primary_text %}
            <a href="{{ cta.primary_href | default('#') }}" class="btn-primary">{{ cta.primary_text }}</a>
            {% endif %}
            {% if cta.secondary_text %}
            <a href="{{ cta.secondary_href | default('#') }}" class="btn-secondary">{{ cta.secondary_text }}</a>
            {% endif %}
        </div>
    </div>
</section>
{% endblock %}

{% block body_scripts %}
<script>
function showTab(tab) {
    var tabs = [{% for tab in (page.content.showcase.tabs | default([])) %}'{{ tab.id }}'{% if not loop.last %}, {% endif %}{% endfor %}];
    for (var i = 0; i < tabs.length; i++) {
        var panel = document.getElementById('panel-' + tabs[i]);
        var btn = document.getElementById('tab-' + tabs[i]);
        if (tabs[i] === tab) {
            panel.style.display = 'block';
            btn.style.background = 'var(--color-primary)';
            btn.style.color = '#fff';
            btn.setAttribute('aria-selected', 'true');
        } else {
            panel.style.display = 'none';
            btn.style.background = '#e5e7eb';
            btn.style.color = 'var(--color-text)';
            btn.setAttribute('aria-selected', 'false');
        }
    }
}
</script>
{% endblock %}
