{# Reviews / Testimonials Page -- dedicated social proof #}
{% extends "base.html.j2" %}

{% block content %}
<!-- Reviews Hero -->
<section class="section-spacing" style="background: {{ brand.accent_color }};">
    <div class="container text-center">
        <h1 class="responsive-h1">{% if page.content.headline %}{{ page.content.headline }}{% else %}Customer Reviews{% endif %}</h1>
        <p class="responsive-p-large">{% if page.content.subheadline %}{{ page.content.subheadline }}{% else %}See what our clients have to say.{% endif %}</p>
        {% if page.content.rating %}
        <div style="margin-top: 1.5rem;">
            <span style="font-size: 2.5rem; font-weight: 700; color: {{ brand.primary_color }};">{{ page.content.rating }}</span>
            <span style="font-size: 1.5rem; color: #f59e0b;">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            {% if page.content.review_count %}
            <span style="display: block; font-size: 0.9rem; opacity: 0.7; margin-top: 0.25rem;">{{ page.content.review_count }} reviews</span>
            {% endif %}
        </div>
        {% endif %}
    </div>
</section>

{% if page.content.featured_review %}
<!-- Featured Review -->
<section class="section-spacing">
    <div class="container" style="max-width: 800px;">
        <div style="background: #fff; border-left: 4px solid {{ brand.primary_color }}; padding: 2.5rem; border-radius: 0 var(--radius) var(--radius) 0; box-shadow: 0 4px 16px rgba(0,0,0,0.06);">
            <blockquote style="font-size: 1.25rem; line-height: 1.8; font-style: italic; margin: 0 0 1.5rem;">
                "{{ page.content.featured_review.quote }}"
            </blockquote>
            <cite style="font-style: normal; font-weight: 600;">
                {{ page.content.featured_review.name }}{% if page.content.featured_review.title %}, {{ page.content.featured_review.title }}{% endif %}
            </cite>
        </div>
    </div>
</section>
{% endif %}

{% if testimonials %}
<!-- All Reviews -->
<section class="section-spacing" style="background: #f9fafb;">
    <div class="container">
        <div class="grid-2" style="gap: 1.5rem;">
            {% for t in testimonials %}
            <div class="card" style="position: relative;">
                <div style="color: {{ brand.primary_color }}; font-size: 2rem; line-height: 1; margin-bottom: 0.5rem; opacity: 0.3;">"</div>
                <p class="responsive-p-body" style="font-style: italic; line-height: 1.7;">{{ t.quote }}</p>
                <div style="margin-top: 1.25rem; display: flex; align-items: center; gap: 0.75rem;">
                    {% if t.photo %}
                    <img src="{{ t.photo }}" alt="{{ t.name }}" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                    {% else %}
                    <div style="width: 40px; height: 40px; border-radius: 50%; background: {{ brand.accent_color }}; display: flex; align-items: center; justify-content: center; font-weight: 700; color: {{ brand.primary_color }}; font-size: 0.85rem;">{{ t.name[:1] }}</div>
                    {% endif %}
                    <div>
                        <div style="font-weight: 600; font-size: 0.9rem;">{{ t.name }}</div>
                        {% if t.title %}
                        <div style="font-size: 0.8rem; opacity: 0.6;">{{ t.title }}{% if t.company %} -- {{ t.company }}{% endif %}</div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if page.content.platforms %}
<!-- Review Platforms -->
<section class="section-spacing">
    <div class="container text-center">
        <h2 class="responsive-h2">Find Us On</h2>
        <div style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem;">
            {% for platform in page.content.platforms %}
            <a href="{{ platform.url }}" target="_blank" rel="noopener" class="card" style="text-decoration: none; color: inherit; min-width: 180px; text-align: center;">
                <div style="font-weight: 700; font-size: 1.1rem;">{{ platform.name }}</div>
                {% if platform.rating %}
                <div style="color: #f59e0b; margin: 0.5rem 0;">&#9733; {{ platform.rating }}</div>
                {% endif %}
                {% if platform.count %}
                <div style="font-size: 0.85rem; opacity: 0.6;">{{ platform.count }} reviews</div>
                {% endif %}
            </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<!-- CTA -->
<section class="section-spacing" style="background: {{ brand.secondary_color }}; color: #fff;">
    <div class="container text-center">
        <h2 class="responsive-h2" style="color: #fff;">{% if page.content.cta_heading %}{{ page.content.cta_heading }}{% else %}Join Our Happy Customers{% endif %}</h2>
        <div class="button-group">
            <a href="{{ page.content.cta_href | default('contact.html') }}" class="btn-primary">{{ page.content.cta_text | default('Get Started') }}</a>
        </div>
    </div>
</section>
{% endblock %}
