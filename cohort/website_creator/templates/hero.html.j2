{# Hero Landing Page -- derived from ChillGuard index.html #}
{% extends "base.html.j2" %}

{% block title %}{{ product_name }} | {{ tagline }}{% endblock %}

{% block content %}
<!-- Hero Section -->
<section class="section-spacing-hero" style="background: linear-gradient(135deg, {{ brand.secondary_color }} 0%, {{ brand.primary_color }} 100%); color: #fff; padding: 4rem 0;">
    <div class="container text-center">
        {% if hero.hero_image %}
        <img src="{{ hero.hero_image }}" alt="{{ product_name }}" style="max-width: 100%; max-height: 300px; object-fit: cover; border-radius: var(--radius); margin-bottom: 2rem;">
        {% endif %}
        <h1 class="responsive-h1" style="color: #fff;">{{ hero.headline }}</h1>
        <p class="responsive-p-large" style="color: rgba(255,255,255,0.9);">{{ hero.subheadline }}</p>
        <div class="button-group">
            {% if hero.cta_primary_text %}
            <a href="{{ hero.cta_primary_href }}" class="btn-primary" style="background: #fff; color: {{ brand.primary_color }};">{{ hero.cta_primary_text }}</a>
            {% endif %}
            {% if hero.cta_secondary_text %}
            <a href="{{ hero.cta_secondary_href }}" class="btn-secondary" style="border-color: #fff; color: #fff;">{{ hero.cta_secondary_text }}</a>
            {% endif %}
        </div>
    </div>
</section>

{% if features %}
<!-- Key Features -->
<section class="section-spacing">
    <div class="container text-center">
        <h2 class="responsive-h2">{% if page.content.features_heading %}{{ page.content.features_heading }}{% else %}Why {{ product_name }}?{% endif %}</h2>
        <div class="grid-3" style="margin-top: 2rem;">
            {% for feature in features[:6] %}
            <div class="card text-center">
                {% if feature.icon %}
                <div style="font-size: 2rem; margin-bottom: 1rem;">{{ feature.icon }}</div>
                {% endif %}
                <h3 class="responsive-h3">{{ feature.title }}</h3>
                <p class="responsive-p-body">{{ feature.description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if testimonials %}
<!-- Social Proof -->
<section class="section-spacing" style="background: {{ brand.accent_color }};">
    <div class="container text-center">
        <h2 class="responsive-h2">What People Say</h2>
        <div class="grid-2" style="margin-top: 2rem;">
            {% for t in testimonials[:4] %}
            <div class="testimonial">
                <blockquote>"{{ t.quote }}"</blockquote>
                <cite>{{ t.name }}{% if t.title %}, {{ t.title }}{% endif %}{% if t.company %} -- {{ t.company }}{% endif %}</cite>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if steps %}
<!-- How It Works (Brief) -->
<section class="section-spacing">
    <div class="container text-center">
        <h2 class="responsive-h2">{% if page.content.steps_heading %}{{ page.content.steps_heading }}{% else %}How It Works{% endif %}</h2>
        <div class="grid-{{ [steps|length, 4] | min }}" style="margin-top: 2rem;">
            {% for step in steps %}
            <div class="text-center">
                <div style="width: 3rem; height: 3rem; border-radius: 50%; background: var(--color-primary); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.25rem; margin-bottom: 1rem;">{{ step.number }}</div>
                <h3 class="responsive-h3">{{ step.title }}</h3>
                <p class="responsive-p-body">{{ step.description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% if pricing_tiers %}
<!-- Pricing Preview -->
<section class="section-spacing" style="background: {{ brand.accent_color }};">
    <div class="container text-center">
        <h2 class="responsive-h2">Pricing</h2>
        <div class="grid-{{ [pricing_tiers|length, 3] | min }}" style="margin-top: 2rem;">
            {% for tier in pricing_tiers %}
            <div class="card{% if tier.highlighted %} card-highlighted{% endif %}" style="position: relative;">
                {% if tier.badge %}
                <div class="pricing-badge">{{ tier.badge }}</div>
                {% endif %}
                <h3 class="responsive-h3">{{ tier.name }}</h3>
                <div style="font-size: 2.5rem; font-weight: 700; color: var(--color-primary); margin: 1rem 0;">{{ tier.price }}<span style="font-size: 1rem; font-weight: 400; color: var(--color-text);">{{ tier.period }}</span></div>
                <p class="responsive-p-body">{{ tier.description }}</p>
                <ul style="text-align: left; list-style: none; padding: 0; margin: 1.5rem 0;">
                    {% for f in tier.features %}
                    <li style="padding: 0.4rem 0; border-bottom: 1px solid #f3f4f6;">[OK] {{ f }}</li>
                    {% endfor %}
                </ul>
                <a href="{{ tier.cta_href }}" class="btn-primary" style="width: 100%;">{{ tier.cta_text }}</a>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<!-- Final CTA -->
<section class="section-spacing" style="background: {{ brand.secondary_color }}; color: #fff;">
    <div class="container text-center">
        <h2 class="responsive-h2" style="color: #fff;">{% if page.content.cta_heading %}{{ page.content.cta_heading }}{% else %}Ready to Get Started?{% endif %}</h2>
        <p class="responsive-p-large" style="color: rgba(255,255,255,0.9);">{% if page.content.cta_subheading %}{{ page.content.cta_subheading }}{% else %}{{ description }}{% endif %}</p>
        <div class="button-group">
            <a href="{{ hero.cta_primary_href | default('#') }}" class="btn-primary" style="background: var(--color-primary);">{{ hero.cta_primary_text | default('Get Started') }}</a>
        </div>
    </div>
</section>
{% endblock %}
