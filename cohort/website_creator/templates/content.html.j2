{# Generic Content Page -- for about, legal, docs, etc. #}
{% extends "base.html.j2" %}

{% block content %}
<!-- Page Header -->
<section class="section-spacing" style="background: {{ brand.accent_color }};">
    <div class="container text-center">
        <h1 class="responsive-h1">{{ page.title }}</h1>
        {% if page.content.subheadline %}
        <p class="responsive-p-large">{{ page.content.subheadline }}</p>
        {% endif %}
    </div>
</section>

<!-- Content Body -->
<section class="section-spacing">
    <div class="container" style="max-width: 800px;">
        {% if page.content.sections %}
            {% for section in page.content.sections %}
            <div style="margin-bottom: 3rem;">
                {% if section.heading %}
                <h2 class="responsive-h2">{{ section.heading }}</h2>
                {% endif %}
                {% if section.body %}
                <div class="responsive-p-body" style="max-width: none;">{{ section.body }}</div>
                {% endif %}
                {% if section.list_items is defined and section.list_items %}
                <ul style="padding-left: 1.5rem; margin-top: 1rem;">
                    {% for item in section.list_items %}
                    <li class="responsive-p-body" style="margin-bottom: 0.5rem;">{{ item }}</li>
                    {% endfor %}
                </ul>
                {% endif %}
            </div>
            {% endfor %}
        {% elif page.content.body %}
            <div class="responsive-p-body" style="max-width: none;">{{ page.content.body }}</div>
        {% endif %}
    </div>
</section>
{% endblock %}
