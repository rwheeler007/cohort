# BOSS Communications Service - Environment Configuration
# Copy this file to .env and fill in your values.

# ===================================================================
# EMAIL (Resend API)
# ===================================================================
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_ADDRESS=BOSS <boss@yourdomain.com>

# ===================================================================
# INCOMING EMAIL (Resend Webhooks)
# ===================================================================
# Email address for receiving incoming emails (configure in Resend dashboard)
INCOMING_EMAIL_ADDRESS=boss@yourdomain.com

# Webhook secret for validating incoming email webhooks from Resend
# Get this from Resend dashboard > Webhooks > Your webhook > Signing secret
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Claude API for AI email classification and routing
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ===================================================================
# GOOGLE CALENDAR
# ===================================================================
# Path to your Google OAuth2 credentials JSON file
# Download from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CREDENTIALS_PATH=data/comms_service/config/google_credentials.json

# ===================================================================
# TWITTER / X (OAuth 2.0)
# ===================================================================
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
# Required scopes: tweet.read, tweet.write, users.read, offline.access
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here

# ===================================================================
# LINKEDIN (OAuth 2.0)
# ===================================================================
# Get credentials from: https://www.linkedin.com/developers/apps
# Required scopes: w_member_social, r_liteprofile, r_emailaddress
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# ===================================================================
# FACEBOOK (OAuth 2.0)
# ===================================================================
# Get credentials from: https://developers.facebook.com/apps
# Required permissions: pages_manage_posts, pages_read_engagement, pages_show_list
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# ===================================================================
# THREADS (Instagram Graph API)
# ===================================================================
# Get credentials from: https://developers.facebook.com/apps
# Required permissions: threads_basic, threads_content_publish
THREADS_APP_ID=your_threads_app_id_here
THREADS_APP_SECRET=your_threads_app_secret_here

# ===================================================================
# REDDIT (OAuth 2.0)
# ===================================================================
# Get credentials from: https://www.reddit.com/prefs/apps
# Create a "script" or "web app" type application
# Required scopes: submit, read, identity
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# ===================================================================
# SMACK INTEGRATION
# ===================================================================
SMACK_URL=http://localhost:5000

# ===================================================================
# SERVICE
# ===================================================================
COMMS_SERVICE_HOST=0.0.0.0
COMMS_SERVICE_PORT=8001
