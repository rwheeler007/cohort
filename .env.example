# Cohort environment variables
# Copy this file to .env and fill in your values.
# These can also be configured via the Settings and Permissions panels in the UI.

# ==============================================================================
# CORE SETTINGS (Settings panel)
# ==============================================================================

# Anthropic API key -- required for agent responses
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path to Claude Code CLI executable (auto-detected if on PATH)
# COHORT_CLAUDE_CMD=claude

# Default model for API-mode task execution
# COHORT_MODEL=claude-sonnet-4-20250514

# Path to agents root directory (where agent configs/prompts live)
# COHORT_AGENTS_ROOT=/path/to/agents

# Override the agents directory (default: ./agents relative to data dir)
# COHORT_AGENTS_DIR=

# Override the data directory (default: ./data relative to project root)
# COHORT_DATA_DIR=

# Agent response timeout in seconds (default: 120)
# RESPONSE_TIMEOUT=120

# Chat server URL -- default is localhost
# COHORT_SERVER_URL=http://127.0.0.1:5100

# Set to "1" to include the full agent system prompt in API responses
# COHORT_FULL_PROMPT=0

# ==============================================================================
# SERVICE KEYS (Permissions panel → Service Keys tab)
# ==============================================================================
# Add keys here for services your agents need access to.
# Per-agent access is controlled in the Permissions panel UI.

# YouTube Data API -- video search, channel info, transcript fetching
# YOUTUBE_API_KEY=AIza...

# RSS Feed Reader -- no key needed for public feeds, optional for premium
# RSS_API_KEY=

# Email (SMTP) -- outgoing email for notifications and agent comms
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password

# Email (IMAP) -- incoming email reading
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=you@gmail.com
# IMAP_PASS=your-app-password

# GitHub API -- repo access, PR creation, issue management
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack Webhook -- post messages to Slack channels
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxxx

# Discord Webhook -- post messages to Discord channels
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/000/xxxx

# OpenAI API -- alternative LLM provider for specific agents
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Cloud API -- Vision, TTS, Translate, etc.
# GOOGLE_CLOUD_API_KEY=AIza...
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Cloudflare API -- Workers, Pages, DNS, R2, etc.
# CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxx

# LinkedIn API -- posting, analytics
# LINKEDIN_CLIENT_ID=xxxxxxxxxxxx
# LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx

# Twitter/X API -- posting, reading timeline
# TWITTER_API_KEY=xxxxxxxxxxxxxxxxxxxx
# TWITTER_API_SECRET=xxxxxxxxxxxxxxxxxxxx
# TWITTER_BEARER_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Reddit API -- posting, reading subreddits
# REDDIT_CLIENT_ID=xxxxxxxxxxxx
# REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx

# AWS Credentials -- S3, Polly, Bedrock, etc.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
# AWS_DEFAULT_REGION=us-east-1

# Custom Webhooks -- any external service with a URL + key
# WEBHOOK_URL=https://your-service.com/api/hook
# WEBHOOK_API_KEY=your-webhook-key

# ==============================================================================
# AGENT API (Pro/Enterprise agent distribution)
# ==============================================================================
# Remote Agent API URL -- where Pro agents are fetched from
# COHORT_AGENTS_API_URL=https://agents.cohort.dev

# API key for the Agent API (determines your tier: free, pro, enterprise)
# COHORT_AGENTS_API_KEY=cohort_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# PUBLISHING (development only)
# ==============================================================================

# PyPI token (scoped to cohort package) -- used for publishing only
# PYPI_TOKEN=pypi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS allowed origins (comma-separated). Defaults to localhost:5100/5200.
# Set this if running the server on a LAN or custom port.
# COHORT_CORS_ORIGINS=http://localhost:5100,http://192.168.1.10:5100
