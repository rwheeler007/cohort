# Cohort environment variables
# Copy this file to .env and fill in your values.

# PyPI token (scoped to cohort package) -- used for publishing only
# PYPI_TOKEN=pypi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key -- only needed if using cohort[claude] extra
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat server URL -- default is localhost
# COHORT_SERVER_URL=http://127.0.0.1:5000
