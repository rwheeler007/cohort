{
  "version": "1.0",
  "default_permission_mode": "acceptEdits",
  "default_max_turns": 10,
  "tool_profiles": {
    "readonly": {
      "description": "Read-only access to the codebase",
      "allowed_tools": [
        "Read",
        "Glob",
        "Grep"
      ],
      "permission_mode": "acceptEdits",
      "max_turns": 5
    },
    "developer": {
      "description": "Full file editing and command execution",
      "allowed_tools": [
        "Read",
        "Write",
        "Edit",
        "Bash",
        "Glob",
        "Grep"
      ],
      "permission_mode": "acceptEdits",
      "max_turns": 15
    },
    "researcher": {
      "description": "Web search via API (paid) and codebase browsing",
      "allowed_tools": [
        "WebSearch",
        "WebFetch",
        "Read",
        "Glob",
        "Grep"
      ],
      "permission_mode": "acceptEdits",
      "max_turns": 10
    },
    "research_local": {
      "description": "Local web rendering via Playwright (free, no API cost)",
      "allowed_tools": [
        "InternalWebFetch",
        "InternalWebSearch",
        "Read",
        "Glob",
        "Grep"
      ],
      "permission_mode": "acceptEdits",
      "max_turns": 10
    },
    "research_hybrid": {
      "description": "Both API and local web access",
      "allowed_tools": [
        "WebSearch",
        "WebFetch",
        "InternalWebFetch",
        "InternalWebSearch",
        "Read",
        "Glob",
        "Grep"
      ],
      "permission_mode": "acceptEdits",
      "max_turns": 10
    },
    "minimal": {
      "description": "No tools - pure text generation",
      "allowed_tools": [],
      "permission_mode": null,
      "max_turns": 1
    }
  },
  "agent_defaults": {
    "core_developers": "minimal",
    "infrastructure": "minimal",
    "leadership": "minimal",
    "marketing_content": "minimal",
    "quality_security": "minimal",
    "social_media": "minimal",
    "specialists": "minimal",
    "support": "minimal"
  },
  "mcp_servers": {
    "cohort": {
      "command": "python",
      "args": [
        "-m",
        "cohort.mcp.server"
      ]
    },
    "local_llm": {
      "command": "python",
      "args": [
        "-m",
        "cohort.mcp.local_llm_server"
      ]
    }
  },
  "denied_tools": [],
  "file_permissions": {
    "defaults": {
      "core_developers": [],
      "infrastructure": [],
      "leadership": [],
      "marketing_content": [],
      "quality_security": [],
      "social_media": [],
      "specialists": [],
      "support": []
    },
    "agent_overrides": {}
  }
}