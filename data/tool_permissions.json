{
  "version": "1.0",
  "default_permission_mode": "acceptEdits",
  "default_max_turns": 10,
  "tool_profiles": {
    "readonly": {
      "description": "Read-only access to the codebase",
      "allowed_tools": [
        "Read",
        "Glob",
        "Grep"
      ],
      "permission_mode": "acceptEdits",
      "max_turns": 5
    },
    "developer": {
      "description": "Full file editing and command execution",
      "allowed_tools": [
        "Read",
        "Write",
        "Edit",
        "Bash",
        "Glob",
        "Grep"
      ],
      "permission_mode": "acceptEdits",
      "max_turns": 15
    },
    "researcher": {
      "description": "Web search via API (paid) and codebase browsing",
      "allowed_tools": [
        "WebSearch",
        "WebFetch",
        "Read",
        "Glob",
        "Grep"
      ],
      "permission_mode": "acceptEdits",
      "max_turns": 10
    },
    "research_local": {
      "description": "Local web rendering via Playwright (free, no API cost)",
      "allowed_tools": [
        "InternalWebFetch",
        "InternalWebSearch",
        "Read",
        "Glob",
        "Grep"
      ],
      "permission_mode": "acceptEdits",
      "max_turns": 10
    },
    "research_hybrid": {
      "description": "Both API and local web access",
      "allowed_tools": [
        "WebSearch",
        "WebFetch",
        "InternalWebFetch",
        "InternalWebSearch",
        "Read",
        "Glob",
        "Grep"
      ],
      "permission_mode": "acceptEdits",
      "max_turns": 10
    },
    "minimal": {
      "description": "No tools - pure text generation",
      "allowed_tools": [],
      "permission_mode": null,
      "max_turns": 1
    }
  },
  "agent_defaults": {
    "core_developers": "developer",
    "infrastructure": "readonly",
    "leadership": "readonly",
    "marketing_content": "researcher",
    "quality_security": "developer",
    "social_media": "researcher",
    "specialists": "developer",
    "support": "readonly"
  },
  "mcp_servers": {
    "cohort": {
      "command": "python",
      "args": [
        "-m",
        "cohort.mcp.server"
      ]
    },
    "local_llm": {
      "command": "python",
      "args": [
        "-m",
        "cohort.mcp.local_llm_server"
      ]
    }
  },
  "denied_tools": [
    "InternalWebFetch",
    "InternalWebSearch"
  ],
  "file_permissions": {
    "defaults": {
      "core_developers": [
        {
          "path": "G:/**",
          "access": "write"
        }
      ],
      "infrastructure": [
        {
          "path": "G:/**",
          "access": "read"
        }
      ],
      "leadership": [
        {
          "path": "G:/**",
          "access": "read"
        }
      ],
      "marketing_content": [
        {
          "path": "G:/**",
          "access": "read"
        }
      ],
      "quality_security": [
        {
          "path": "G:/**",
          "access": "write"
        }
      ],
      "social_media": [],
      "specialists": [
        {
          "path": "G:/**",
          "access": "write"
        }
      ],
      "support": [
        {
          "path": "G:/**",
          "access": "read"
        }
      ]
    },
    "agent_overrides": {}
  }
}