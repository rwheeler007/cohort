{
  "version": "1.0",
  "default_permission_mode": "acceptEdits",
  "default_max_turns": 10,
  "tool_profiles": {
    "readonly": {
      "description": "Read-only access to the codebase",
      "allowed_tools": ["Read", "Glob", "Grep"],
      "permission_mode": "acceptEdits",
      "max_turns": 5
    },
    "developer": {
      "description": "Full file editing and command execution",
      "allowed_tools": ["Read", "Write", "Edit", "Bash", "Glob", "Grep"],
      "permission_mode": "acceptEdits",
      "max_turns": 15
    },
    "researcher": {
      "description": "Web search via API (paid) and codebase browsing",
      "allowed_tools": ["WebSearch", "WebFetch", "Read", "Glob", "Grep"],
      "permission_mode": "acceptEdits",
      "max_turns": 10
    },
    "research_local": {
      "description": "Local web rendering via Playwright (free, no API cost)",
      "allowed_tools": ["InternalWebFetch", "InternalWebSearch", "Read", "Glob", "Grep"],
      "permission_mode": "acceptEdits",
      "max_turns": 10
    },
    "research_hybrid": {
      "description": "Both API and local web access",
      "allowed_tools": ["WebSearch", "WebFetch", "InternalWebFetch", "InternalWebSearch", "Read", "Glob", "Grep"],
      "permission_mode": "acceptEdits",
      "max_turns": 10
    },
    "minimal": {
      "description": "No tools - pure text generation",
      "allowed_tools": [],
      "permission_mode": null,
      "max_turns": 1
    }
  },
  "agent_defaults": {
    "leadership": "readonly",
    "core_developers": "developer",
    "quality_security": "developer",
    "marketing_content": "researcher",
    "social_media": "researcher",
    "support": "readonly",
    "specialists": "developer",
    "infrastructure": "readonly",
    "specialist": "developer",
    "orchestrator": "readonly",
    "utility": "minimal"
  },
  "mcp_servers": {
    "cohort": {
      "command": "python",
      "args": ["-m", "cohort.mcp.server"]
    },
    "local_llm": {
      "command": "python",
      "args": ["-m", "cohort.mcp.local_llm_server"]
    }
  },
  "denied_tools": ["TodoWrite"],
  "file_permissions": {
    "defaults": {
      "core_developers": [
        { "path": "G:/**", "access": "write" }
      ],
      "quality_security": [
        { "path": "G:/**", "access": "write" }
      ],
      "specialists": [
        { "path": "G:/**", "access": "write" }
      ],
      "leadership": [
        { "path": "G:/**", "access": "read" }
      ],
      "infrastructure": [
        { "path": "G:/**", "access": "read" }
      ],
      "support": [
        { "path": "G:/**", "access": "read" }
      ],
      "marketing_content": [
        { "path": "G:/**", "access": "read" }
      ],
      "social_media": [],
      "utility": []
    },
    "agent_overrides": {}
  }
}
